    footer strong { color: var(--gold3); }

    /* ── RESPONSIVE ── */
    @media (max-width: 860px) {
      .pains { grid-template-columns: 1fr; }
      .feat-grid { grid-template-columns: 1fr 1fr; }
      .testi-grid { grid-template-columns: 1fr; }
      .demo-wrap { grid-template-columns: 1fr; }
      .sales-phones { grid-template-columns: 1fr; gap: 48px; }
      .sales-phone-col { flex-direction: row; align-items: flex-start; gap: 20px; max-width: 480px; margin: 0 auto; }
      .sales-step-label { flex-direction: column; flex-shrink: 0; width: auto; }
    }
    @media (max-width: 520px) {
      .sales-phone-col { flex-direction: column; align-items: center; }
      .sales-step-label { flex-direction: row; align-items: flex-start; width: 100%; max-width: 280px; }
    }
    @media (max-width: 600px) {
      nav { padding: 12px 16px; }
      .nav-price { display: none; }
      .sticky-cta { display: block; }
      .feat-grid { grid-template-columns: 1fr; }
      .reg-card { padding: 32px 22px; }
      .price-body { padding: 26px 22px; }
      .price-head { padding: 32px 22px 26px; }
    }

    /* ── ANIMATION ── */
    .fade-in { opacity: 0; transform: translateY(28px); transition: opacity .7s, transform .7s; }
    .fade-in.visible { opacity: 1; transform: none; }
  </style>
</head>
