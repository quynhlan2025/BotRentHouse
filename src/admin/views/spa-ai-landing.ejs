    .price-save { display: inline-block; background: var(--ivory2); color: var(--gold2); border: 1px solid var(--gold3); padding: 4px 14px; font-size: 12px; font-weight: 600; margin-top: 10px; font-family: 'Segoe UI', sans-serif; letter-spacing: .3px; }
