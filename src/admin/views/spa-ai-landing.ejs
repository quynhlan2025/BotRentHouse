<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Trợ Lý AI Spa – Đặt Lịch Tự Động 24/7 | Chỉ 200K/tháng</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --gold:    #b8945a;
      --gold2:   #9a7a48;
      --gold3:   #d4b07a;
      --ivory:   #faf8f5;
      --ivory2:  #f2ede6;
      --ivory3:  #e8e0d4;
      --charcoal:#1c1c1c;
      --slate:   #3a3a3a;
      --muted:   #7a7068;
      --light:   #f6f3ee;
    }
    html { scroll-behavior: smooth; }
    body { font-family: 'Georgia', 'Segoe UI', serif; color: var(--charcoal); background: var(--ivory); overflow-x: hidden; }

    /* ── NAV ── */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 200;
      background: rgba(250,248,245,.97); backdrop-filter: blur(14px);
      padding: 14px 40px; display: flex; align-items: center; justify-content: space-between;
      border-bottom: 1px solid var(--ivory3);
    }
    .logo { font-size: 15px; font-weight: 700; color: var(--charcoal); letter-spacing: 1.5px; text-transform: uppercase; display: flex; align-items: center; gap: 10px; font-family: 'Segoe UI', sans-serif; }
    .logo-mark { width: 34px; height: 34px; border: 1.5px solid var(--gold); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 15px; }
    .nav-right { display: flex; align-items: center; gap: 18px; }
    .nav-price { font-size: 12px; font-weight: 600; color: var(--gold2); letter-spacing: .5px; font-family: 'Segoe UI', sans-serif; }
    .nav-cta { background: var(--charcoal); color: var(--ivory); padding: 9px 22px; border-radius: 4px; font-size: 12px; font-weight: 600; text-decoration: none; letter-spacing: .8px; text-transform: uppercase; font-family: 'Segoe UI', sans-serif; transition: background .2s; }
    .nav-cta:hover { background: var(--gold2); }

    /* ── URGENCY BAR ── */
    .urgency-bar {
      background: var(--charcoal); color: #d4c4a8;
      text-align: center; padding: 10px 20px; font-size: 12px; letter-spacing: .6px;
      margin-top: 62px; font-family: 'Segoe UI', sans-serif;
    }
    .urgency-bar strong { color: var(--gold3); }
    #countdown { font-weight: 700; color: white; }

    /* ── HERO ── */
    .hero {
      padding: 90px 20px 80px;
      background: linear-gradient(170deg, var(--ivory) 0%, var(--ivory2) 60%, var(--ivory3) 100%);
      text-align: center; position: relative; overflow: hidden;
    }
    .hero::before {
      content: ''; position: absolute; top: -60px; right: -60px;
      width: 380px; height: 380px; border-radius: 50%;
      background: radial-gradient(circle, rgba(184,148,90,.08) 0%, transparent 70%);
      pointer-events: none;
    }
    .hero-eyebrow {
      display: inline-block; color: var(--gold2); font-size: 11px; font-weight: 600;
      letter-spacing: 3px; text-transform: uppercase; margin-bottom: 22px;
      font-family: 'Segoe UI', sans-serif;
    }
    .hero h1 {
      font-size: clamp(30px, 5vw, 58px); font-weight: 700; line-height: 1.18;
      margin-bottom: 20px; letter-spacing: -.5px; color: var(--charcoal);
    }
    .hero h1 em { font-style: italic; color: var(--gold2); }
    .hero-sub { font-size: 16px; color: var(--muted); max-width: 520px; margin: 0 auto 40px; line-height: 1.8; font-family: 'Segoe UI', sans-serif; }
    .hero-ctas { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; margin-bottom: 48px; }
    .btn-main {
      background: var(--charcoal); color: var(--ivory);
      padding: 15px 38px; border-radius: 4px; font-size: 13px; font-weight: 600;
      text-decoration: none; letter-spacing: 1px; text-transform: uppercase;
      font-family: 'Segoe UI', sans-serif; transition: background .2s;
    }
    .btn-main:hover { background: var(--gold2); }
    .btn-outline {
      border: 1.5px solid var(--gold); color: var(--gold2); background: transparent;
      padding: 15px 38px; border-radius: 4px; font-size: 13px; font-weight: 600;
      text-decoration: none; letter-spacing: 1px; text-transform: uppercase;
      font-family: 'Segoe UI', sans-serif; transition: all .2s;
    }
    .btn-outline:hover { background: var(--gold); color: white; }
    .hero-divider { width: 60px; height: 1px; background: var(--gold3); margin: 0 auto 28px; }
    .hero-trust { display: flex; gap: 32px; justify-content: center; flex-wrap: wrap; }
    .trust-item { display: flex; align-items: center; gap: 8px; font-size: 12px; color: var(--muted); letter-spacing: .4px; font-family: 'Segoe UI', sans-serif; }
    .trust-dot { width: 5px; height: 5px; background: var(--gold3); border-radius: 50%; }

    /* ── HERO PHONES ROW ── */
    .hero { padding-bottom: 0; }
    .hero-content { padding-bottom: 52px; }
    .hero-phones-outer {
      overflow-x: auto; -webkit-overflow-scrolling: touch;
      scrollbar-width: none; border-top: 1px solid var(--ivory3);
      background: linear-gradient(180deg, var(--ivory2) 0%, var(--ivory3) 100%);
    }
    .hero-phones-outer::-webkit-scrollbar { display: none; }
    .hero-phones-scroll {
      display: flex; gap: 16px; width: fit-content;
      margin: 0 auto; padding: 40px 40px 48px;
    }
    .hp-col { display: flex; flex-direction: column; align-items: center; gap: 14px; }
    .hp-label {
      font-size: 10.5px; font-weight: 700; color: var(--gold2);
      letter-spacing: .8px; text-transform: uppercase;
      font-family: 'Segoe UI', sans-serif; text-align: center; line-height: 1.5;
    }

    /* XS phone shell */
    .phone-xs {
      width: 178px; position: relative; border-radius: 38px; padding: 8px 7px;
      background: linear-gradient(160deg, #2c2c2e 0%, #1c1c1e 50%, #2a2a2c 100%);
      box-shadow: 0 0 0 1.5px #48484a, 0 0 0 2.5px #3a3a3c,
                  0 24px 64px rgba(0,0,0,.55), 0 6px 18px rgba(0,0,0,.4);
    }
    .phone-xs::before { content:''; position:absolute; right:-3px; top:72px; width:2.5px; height:42px; background:#3a3a3c; border-radius:0 2px 2px 0; box-shadow:0 0 0 1px #48484a; }
    .phone-xs::after  { content:''; position:absolute; left:-3px; top:64px; width:2.5px; height:28px; background:#3a3a3c; border-radius:2px 0 0 2px; box-shadow:0 0 0 1px #48484a, 0 38px 0 0 #3a3a3c, 0 38px 0 1px #48484a, 0 72px 0 0 #3a3a3c, 0 72px 0 1px #48484a; }
    .phone-xs .screen { border-radius: 32px; overflow: hidden; }
    .di-xs { position:absolute; top:7px; left:50%; transform:translateX(-50%); width:72px; height:21px; background:#000; border-radius:14px; z-index:10; }

    /* XS Zalo header */
    .zb-xs { background:#0068ff; color:white; padding:6px 10px 0; }
    .zs-xs { display:flex; justify-content:space-between; font-size:7.5px; opacity:.9; padding-top:27px; margin-bottom:5px; }
    .zh-xs { display:flex; align-items:center; gap:7px; padding-bottom:8px; }
    .za-xs { width:24px; height:24px; border-radius:50%; background:linear-gradient(135deg,#b8945a,#d4b07a); display:flex; align-items:center; justify-content:center; font-size:11px; flex-shrink:0; }
    .zn-xs { font-size:11px; font-weight:700; line-height:1.2; }
    .zsu-xs{ font-size:7.5px; opacity:.8; }

    /* XS chat body */
    .zb-xs-body { background:#f0f2f5; padding:8px; display:flex; flex-direction:column; gap:5px; min-height:272px; }
    .bb { background:white; color:#222; align-self:flex-start; max-width:90%; padding:6px 8px; font-size:9.5px; line-height:1.55; border-radius:2px 8px 8px 8px; box-shadow:0 1px 2px rgba(0,0,0,.07); }
    .bm { background:#d9f2ff; color:#003d99; align-self:flex-end; max-width:85%; padding:6px 8px; font-size:9.5px; line-height:1.5; border-radius:8px 2px 8px 8px; }
    .bbtns { display:flex; flex-wrap:wrap; gap:3px; margin-top:5px; }
    .bbn { background:var(--ivory2); border:1px solid var(--ivory3); color:var(--slate); padding:3px 7px; border-radius:3px; font-size:9px; font-weight:600; font-family:'Segoe UI',sans-serif; white-space:nowrap; }
    .bbn-dark { background:var(--charcoal) !important; border-color:var(--charcoal) !important; color:var(--ivory) !important; }

    /* XS input bar */
    .zi-xs { background:white; padding:6px 8px; display:flex; align-items:center; gap:5px; border-top:1px solid #e8e8e8; }
    .zin-xs { flex:1; background:#f0f2f5; border-radius:12px; padding:4px 9px; font-size:9.5px; color:#999; }
    .zsd-xs { width:22px; height:22px; background:#0068ff; border-radius:50%; display:flex; align-items:center; justify-content:center; color:white; font-size:9px; }

    /* ── PROOF BAR ── */
    .proof-bar { background: var(--charcoal); padding: 36px 20px; }
    .proof-inner { max-width: 860px; margin: 0 auto; display: flex; justify-content: space-around; flex-wrap: wrap; gap: 24px; }
    .proof-item { text-align: center; }
    .proof-num { font-size: 30px; font-weight: 700; color: var(--gold3); line-height: 1; letter-spacing: -1px; }
    .proof-lbl { font-size: 11px; color: #a09888; margin-top: 6px; letter-spacing: .8px; text-transform: uppercase; font-family: 'Segoe UI', sans-serif; }

    /* ── SECTION ── */
    .sec { padding: 80px 20px; }
    .sec-light { background: white; }
    .sec-ivory { background: var(--ivory2); }
    .sec-dark  { background: var(--charcoal); }
    .sec-eyebrow { text-align: center; color: var(--gold2); font-size: 11px; font-weight: 600; letter-spacing: 3px; text-transform: uppercase; margin-bottom: 14px; font-family: 'Segoe UI', sans-serif; }
    .sec-title { text-align: center; font-size: clamp(24px, 3vw, 36px); font-weight: 700; margin-bottom: 12px; letter-spacing: -.3px; }
    .sec-title-light { color: white; }
    .sec-rule { width: 48px; height: 1px; background: var(--gold3); margin: 0 auto 20px; }
    .sec-sub { text-align: center; color: var(--muted); font-size: 15px; max-width: 480px; margin: 0 auto 52px; line-height: 1.75; font-family: 'Segoe UI', sans-serif; }
    .sec-sub-light { color: #a09888; }

    /* ── PAIN POINTS ── */
    .pains { max-width: 800px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
    .pain {
      background: var(--ivory); border: 1px solid var(--ivory3); border-top: 3px solid var(--gold);
      border-radius: 4px; padding: 24px 26px;
    }
    .pain-num { font-size: 11px; font-weight: 600; color: var(--gold2); letter-spacing: 2px; text-transform: uppercase; margin-bottom: 10px; font-family: 'Segoe UI', sans-serif; }
    .pain h4 { font-size: 15px; font-weight: 700; margin-bottom: 7px; line-height: 1.4; }
    .pain p  { font-size: 13px; color: var(--muted); line-height: 1.65; font-family: 'Segoe UI', sans-serif; }

    /* ── FEATURES ── */
    .feat-grid { max-width: 940px; margin: 0 auto; display: grid; grid-template-columns: repeat(3,1fr); gap: 2px; background: var(--ivory3); border: 1px solid var(--ivory3); }
    .feat-card {
      background: white; padding: 36px 28px;
      transition: background .2s;
    }
    .feat-card:hover { background: var(--ivory); }
    .feat-line { width: 32px; height: 2px; background: var(--gold); margin-bottom: 18px; }
    .feat-card h3 { font-size: 16px; font-weight: 700; margin-bottom: 10px; line-height: 1.35; }
    .feat-card p  { font-size: 13px; color: var(--muted); line-height: 1.7; font-family: 'Segoe UI', sans-serif; }
    .feat-tag { display: inline-block; background: var(--charcoal); color: var(--gold3); font-size: 9px; font-weight: 700; padding: 2px 8px; border-radius: 2px; margin-left: 6px; letter-spacing: 1px; font-family: 'Segoe UI', sans-serif; vertical-align: middle; }

    /* ── DEMO ── */
    .demo-wrap { max-width: 1000px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center; }
    .demo-text .eyebrow { font-size: 11px; color: #a09888; letter-spacing: 3px; text-transform: uppercase; margin-bottom: 16px; font-family: 'Segoe UI', sans-serif; font-weight: 600; }
    .demo-text h2 { font-size: clamp(22px,2.5vw,32px); font-weight: 700; margin-bottom: 16px; line-height: 1.3; color: white; }
    .demo-text p  { font-size: 14px; color: #a09888; line-height: 1.8; margin-bottom: 24px; font-family: 'Segoe UI', sans-serif; }
    .demo-steps { display: flex; flex-direction: column; gap: 18px; }
    .demo-step  { display: flex; align-items: flex-start; gap: 16px; }
    .step-num   { width: 26px; height: 26px; border: 1px solid var(--gold); color: var(--gold3); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 600; flex-shrink: 0; margin-top: 2px; font-family: 'Segoe UI', sans-serif; }
    .step-text  { font-size: 13px; color: #c4b9a8; line-height: 1.6; padding-top: 3px; font-family: 'Segoe UI', sans-serif; }
    .step-text strong { color: white; }

    /* iPhone shell */
    .phone-wrap { display: flex; justify-content: center; }
    .phone {
      width: 232px; position: relative; border-radius: 46px; padding: 11px 9px;
      background: linear-gradient(160deg, #2c2c2e 0%, #1c1c1e 50%, #2a2a2c 100%);
      box-shadow: 0 0 0 1.5px #48484a, 0 0 0 3px #3a3a3c, 0 32px 80px rgba(0,0,0,.7), 0 8px 24px rgba(0,0,0,.5);
    }
    .phone::before { content:''; position:absolute; right:-3.5px; top:88px; width:3px; height:50px; background:#3a3a3c; border-radius:0 3px 3px 0; box-shadow:0 0 0 1px #48484a; }
    .phone::after  { content:''; position:absolute; left:-3.5px; top:78px; width:3px; height:34px; background:#3a3a3c; border-radius:3px 0 0 3px; box-shadow:0 0 0 1px #48484a, 0 46px 0 0 #3a3a3c, 0 46px 0 1px #48484a, 0 86px 0 0 #3a3a3c, 0 86px 0 1px #48484a; }
    .screen { border-radius: 38px; overflow: hidden; }
    .dynamic-island { position:absolute; top:9px; left:50%; transform:translateX(-50%); width:90px; height:27px; background:#000; border-radius:18px; z-index:10; }

    /* Zalo */
    .zalo-bar { background:#0068ff; color:white; padding:8px 12px 0; }
    .zalo-status { display:flex; justify-content:space-between; font-size:8.5px; opacity:.9; margin-bottom:6px; padding-top:34px; }
    .zalo-header { display:flex; align-items:center; gap:8px; padding-bottom:10px; }
    .zalo-av { width:30px; height:30px; border-radius:50%; background:linear-gradient(135deg,#b8945a,#d4b07a); display:flex; align-items:center; justify-content:center; font-size:14px; }
    .zalo-info .zname { font-size:12.5px; font-weight:700; }
    .zalo-info .zsub  { font-size:8.5px; opacity:.8; }
    .zalo-icons { margin-left:auto; display:flex; gap:9px; font-size:13px; opacity:.9; }
    .zalo-body  { background:#f0f2f5; padding:10px; display:flex; flex-direction:column; gap:6px; min-height:320px; }
    .zm  { max-width:85%; padding:7px 10px; font-size:11px; line-height:1.55; border-radius:8px; }
    .zmb { background:white; color:#222; align-self:flex-start; border-radius:2px 10px 10px 10px; box-shadow:0 1px 2px rgba(0,0,0,.08); }
    .zmu { background:#d9f2ff; color:#003d99; align-self:flex-end; border-radius:10px 2px 10px 10px; }
    .zbtns { display:flex; flex-wrap:wrap; gap:4px; margin-top:5px; }
    .zbtn { background:#f5f0e8; border:1px solid #c9a96e; color:#7a5c2e; padding:3px 8px; border-radius:3px; font-size:10px; font-weight:600; }
    .zalo-input { background:white; padding:7px 10px; display:flex; align-items:center; gap:6px; border-top:1px solid #e8e8e8; }
    .zinput { flex:1; background:#f0f2f5; border-radius:18px; padding:5px 11px; font-size:10.5px; color:#999; }
    .zsend { width:26px; height:26px; background:#0068ff; border-radius:50%; display:flex; align-items:center; justify-content:center; color:white; font-size:11px; }

    /* ── SALES DEMO 3 PHONES ── */
    .sales-phones { max-width: 1060px; margin: 0 auto; display: grid; grid-template-columns: repeat(3,1fr); gap: 32px; align-items: start; }
    .sales-phone-col { display: flex; flex-direction: column; align-items: center; gap: 24px; }
    .sales-step-label { display: flex; align-items: flex-start; gap: 14px; width: 100%; max-width: 280px; }
    .sales-step-num { font-size: 13px; font-weight: 700; color: var(--gold); border: 1px solid var(--gold3); width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-family: 'Segoe UI', sans-serif; margin-top: 2px; }
    .sales-step-title { font-size: 14px; font-weight: 700; margin-bottom: 5px; }
    .sales-step-desc  { font-size: 12px; color: var(--muted); line-height: 1.6; font-family: 'Segoe UI', sans-serif; }

    /* Smaller phone variant */
    .phone-sm { width: 200px; border-radius: 40px; padding: 9px 8px; }
    .di-sm { width: 76px !important; height: 22px !important; top: 8px !important; }
    .zb-sm { padding: 7px 10px 0; }
    .zs-sm { font-size: 7.5px; padding-top: 28px; margin-bottom: 5px; }
    .zh-sm { padding-bottom: 8px; }
    .za-sm { width: 26px !important; height: 26px !important; font-size: 12px !important; }
    .zn-sm { font-size: 11.5px !important; }
    .zsu-sm{ font-size: 7.5px !important; }
    .zb-body-sm { padding: 9px; min-height: 290px !important; }
    .zm-sm  { max-width: 88%; padding: 6px 9px; font-size: 10px; line-height: 1.5; border-radius: 7px; }
    .zmb-sm { background: white; color: #222; align-self: flex-start; border-radius: 2px 9px 9px 9px; box-shadow: 0 1px 2px rgba(0,0,0,.07); }
    .zmu-sm { background: #d9f2ff; color: #003d99; align-self: flex-end; border-radius: 9px 2px 9px 9px; }
    .zbtns-sm { display: flex; flex-wrap: wrap; gap: 3px; margin-top: 5px; }
    .zbtn-sm { background: var(--ivory2); border: 1px solid var(--ivory3); color: var(--slate); padding: 3px 7px; border-radius: 3px; font-size: 9.5px; font-weight: 600; font-family: 'Segoe UI', sans-serif; }
    .zbtn-gold { background: var(--charcoal) !important; border-color: var(--charcoal) !important; color: var(--ivory) !important; }
    .zi-sm { background: white; padding: 6px 9px; display: flex; align-items: center; gap: 5px; border-top: 1px solid #e8e8e8; }
    .zinput-sm { flex:1; background: #f0f2f5; border-radius: 14px; padding: 5px 10px; font-size: 10px; color: #999; }
    .zsend-sm  { width: 24px; height: 24px; background: #0068ff; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-size: 10px; }

    /* Chat bubble appear animation */
    .chat-bubble { opacity: 0; animation: bubbleIn .4s ease forwards; animation-delay: calc(var(--d, 0s) + .3s); }
    @keyframes bubbleIn { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:none; } }

    /* Typing dots */
    .typing-dots { background: white; align-self: flex-start; padding: 8px 12px; border-radius: 2px 9px 9px 9px; box-shadow: 0 1px 2px rgba(0,0,0,.07); display: flex; gap: 3px; align-items: center; opacity:0; animation: bubbleIn .4s ease forwards; animation-delay: calc(var(--d, 0s) + .3s); }
    .typing-dots span { width: 5px; height: 5px; background: #bbb; border-radius: 50%; animation: typingBounce 1.2s infinite; }
    .typing-dots span:nth-child(2) { animation-delay: .2s; }
    .typing-dots span:nth-child(3) { animation-delay: .4s; }
    @keyframes typingBounce { 0%,60%,100% { transform: translateY(0); } 30% { transform: translateY(-4px); } }

    /* ── TESTIMONIALS ── */
    .testi-grid { max-width: 900px; margin: 0 auto; display: grid; grid-template-columns: repeat(3,1fr); gap: 24px; }
    .testi-card { background: white; border: 1px solid var(--ivory3); border-top: 2px solid var(--gold); padding: 28px 24px; }
    .testi-stars { color: var(--gold); font-size: 13px; letter-spacing: 2px; margin-bottom: 14px; }
    .testi-text { font-size: 14px; color: #444; line-height: 1.75; margin-bottom: 20px; font-style: italic; }
    .testi-line { width: 24px; height: 1px; background: var(--gold3); margin-bottom: 14px; }
    .testi-name { font-size: 13px; font-weight: 700; margin-bottom: 3px; font-family: 'Segoe UI', sans-serif; }
    .testi-role { font-size: 11px; color: var(--muted); font-family: 'Segoe UI', sans-serif; letter-spacing: .3px; }

    /* ── FAQ ── */
    .faq-list { max-width: 700px; margin: 0 auto; }
    .faq-item { border-bottom: 1px solid var(--ivory3); }
    .faq-q {
      padding: 20px 0; font-size: 15px; font-weight: 600; cursor: pointer;
      display: flex; justify-content: space-between; align-items: center;
      list-style: none; user-select: none; color: var(--charcoal);
    }
    .faq-q::after { content: '+'; font-size: 22px; color: var(--gold); font-weight: 300; transition: transform .25s; flex-shrink: 0; }
    .faq-item.open .faq-q::after { transform: rotate(45deg); }
    .faq-a { font-size: 14px; color: var(--muted); line-height: 1.8; padding: 0 0 20px; display: none; font-family: 'Segoe UI', sans-serif; }
    .faq-item.open .faq-a { display: block; }

    /* ── PRICING ── */
    .pricing-wrap { max-width: 580px; margin: 0 auto; }
    .price-card { background: white; border: 1px solid var(--ivory3); }
    .price-head { background: var(--charcoal); color: white; padding: 40px 36px 32px; text-align: center; }
