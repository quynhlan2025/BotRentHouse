    .reg-title { font-size: 24px; font-weight: 700; text-align: center; margin-bottom: 8px; }
    .reg-sub { text-align: center; color: var(--muted); font-size: 14px; margin-bottom: 32px; font-family: 'Segoe UI', sans-serif; line-height: 1.65; }
    .form-group { margin-bottom: 18px; }
    .form-label { display: block; font-size: 11px; font-weight: 700; margin-bottom: 7px; color: var(--slate); letter-spacing: 1px; text-transform: uppercase; font-family: 'Segoe UI', sans-serif; }
    .form-input {
      width: 100%; padding: 13px 16px; border: 1px solid var(--ivory3); background: var(--ivory);
      font-size: 14px; outline: none; transition: border-color .2s; border-radius: 2px;
      font-family: 'Segoe UI', sans-serif; color: var(--charcoal);
    }
    .form-input:focus { border-color: var(--gold); background: white; }
    .form-submit {
      width: 100%; padding: 15px; background: var(--charcoal); color: var(--ivory);
      border: none; font-size: 13px; font-weight: 600; cursor: pointer;
      letter-spacing: 1.5px; text-transform: uppercase; transition: background .2s;
      font-family: 'Segoe UI', sans-serif;
    }
    .form-submit:hover { background: var(--gold2); }
    .form-note { text-align: center; font-size: 12px; color: var(--muted); margin-top: 12px; font-family: 'Segoe UI', sans-serif; }

    /* ── STICKY CTA (mobile) ── */
    .sticky-cta { display: none; position: fixed; bottom: 0; left: 0; right: 0; z-index: 150; padding: 12px 16px; background: white; border-top: 1px solid var(--ivory3); }
    .sticky-cta a { display: block; text-align: center; background: var(--charcoal); color: var(--ivory); padding: 14px; font-size: 13px; font-weight: 600; text-decoration: none; letter-spacing: 1px; text-transform: uppercase; font-family: 'Segoe UI', sans-serif; }

    /* ── FOOTER ── */
