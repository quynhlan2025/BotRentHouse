<script>
  // ── Countdown Timer ──────────────────────────────────────────────
  (function() {
    // Lấy hoặc tạo deadline = cuối ngày hôm nay
    const key = 'spa_ai_deadline';
    let deadline = localStorage.getItem(key);
    if (!deadline) {
      const end = new Date();
      end.setHours(23, 59, 59, 0);
      deadline = end.getTime();
      localStorage.setItem(key, deadline);
    }
    function tick() {
      const now  = Date.now();
      const diff = Math.max(0, deadline - now);
      const h = String(Math.floor(diff / 3600000)).padStart(2,'0');
      const m = String(Math.floor((diff % 3600000) / 60000)).padStart(2,'0');
      const s = String(Math.floor((diff % 60000) / 1000)).padStart(2,'0');
      const el = document.getElementById('countdown');
      if (el) el.textContent = `${h}:${m}:${s}`;
    }
    tick();
    setInterval(tick, 1000);
  })();

  // ── Fake slot counter ─────────────────────────────────────────────
  (function() {
    const key = 'spa_ai_slots';
    let slots = parseInt(localStorage.getItem(key) || '11');
    // Giảm 1–2 mỗi lần load trang (giả lập người dùng khác đăng ký)
    const reduce = Math.floor(Math.random() * 2);
    slots = Math.max(3, slots - reduce);
    localStorage.setItem(key, slots);
    document.querySelectorAll('#slots, #slots2').forEach(el => { if(el) el.textContent = slots; });
  })();

  // ── FAQ accordion ─────────────────────────────────────────────────
  document.querySelectorAll('.faq-q').forEach(q => {
    q.addEventListener('click', () => {
      const item = q.closest('.faq-item');
      const wasOpen = item.classList.contains('open');
      document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));
      if (!wasOpen) item.classList.add('open');
    });
  });

  // ── Register form ─────────────────────────────────────────────────
  function handleRegister(e) {
    e.preventDefault();
    const btn = document.getElementById('regBtn');
    btn.textContent = '⏳ Đang gửi...';
    btn.disabled = true;

    const data = {
      name:  document.getElementById('reg-name').value,
      phone: document.getElementById('reg-phone').value,
      spa:   document.getElementById('reg-spa').value,
      city:  document.getElementById('reg-city').value,
    };

    // Gửi về server (hoặc Zalo/Telegram webhook)
    fetch('/api/spa-register', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data),
    }).catch(() => {}).finally(() => {
      document.getElementById('regForm').style.display  = 'none';
      document.getElementById('regSuccess').style.display = 'block';
      // Giảm slot
      const key = 'spa_ai_slots';
      const slots = Math.max(2, parseInt(localStorage.getItem(key) || '5') - 1);
      localStorage.setItem(key, slots);
      document.querySelectorAll('#slots, #slots2').forEach(el => { if(el) el.textContent = slots; });
    });
  }

  // ── Scroll fade-in ────────────────────────────────────────────────
  const observer = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.1 });
  document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));
</script>
</body>
</html>
