        <div class="form-group">
          <label class="form-label">Tên spa của bạn</label>
          <input class="form-input" type="text" placeholder="VD: Beauty Spa Hương Ly" required id="reg-spa">
        </div>
        <div class="form-group">
          <label class="form-label">Tỉnh / Thành phố</label>
          <select class="form-input" id="reg-city">
            <option value="">Chọn tỉnh thành...</option>
            <option>TP. Hồ Chí Minh</option>
            <option>Hà Nội</option>
            <option>Đà Nẵng</option>
            <option>Bình Dương</option>
            <option>Đồng Nai</option>
            <option>Cần Thơ</option>
            <option>Khác</option>
          </select>
        </div>
        <button type="submit" class="form-submit" id="regBtn">Đăng ký dùng thử miễn phí</button>
        <p class="form-note">Thông tin của bạn được bảo mật · Không spam</p>
      </form>

      <div id="regSuccess" style="display:none;text-align:center;padding:24px 0;">
        <div style="font-size:36px;margin-bottom:14px;">✦</div>
        <h3 style="font-size:20px;margin-bottom:10px;color:var(--charcoal);">Đăng ký thành công</h3>
        <p style="color:var(--muted);font-size:14px;line-height:1.75;font-family:'Segoe UI',sans-serif;">Đội hỗ trợ sẽ liên hệ bạn trong <strong>30 phút</strong> để tiến hành setup.<br>Trong khi chờ, hãy nhắn Zalo để được tư vấn nhanh hơn.</p>
      </div>
    </div>
  </div>
</section>

<!-- STICKY CTA -->
<div class="sticky-cta">
  <a href="#register">Dùng thử miễn phí — 200.000đ / tháng</a>
</div>

<!-- FOOTER -->
<footer>
  <p>© 2025 <strong>Trợ Lý AI Spa</strong> · Sản phẩm công nghệ dành cho spa Việt Nam</p>
  <p style="margin-top:8px;">Hotline & Zalo: <strong>0901 234 567</strong></p>
</footer>

<script>
  // Countdown Timer
  (function() {
    const key = 'spa_ai_dl2';
    let deadline = localStorage.getItem(key);
    if (!deadline) {
      const end = new Date(); end.setHours(23,59,59,0);
      deadline = end.getTime(); localStorage.setItem(key, deadline);
    }
    function tick() {
      const diff = Math.max(0, deadline - Date.now());
      const h = String(Math.floor(diff/3600000)).padStart(2,'0');
      const m = String(Math.floor((diff%3600000)/60000)).padStart(2,'0');
      const s = String(Math.floor((diff%60000)/1000)).padStart(2,'0');
      const el = document.getElementById('countdown');
      if (el) el.textContent = `${h}:${m}:${s}`;
    }
    tick(); setInterval(tick, 1000);
  })();

  // Slot counter
  (function() {
    const key = 'spa_ai_sl2';
    let slots = parseInt(localStorage.getItem(key) || '11');
    slots = Math.max(3, slots - Math.floor(Math.random()*2));
    localStorage.setItem(key, slots);
    document.querySelectorAll('#slots,#slots2').forEach(el => { if(el) el.textContent = slots; });
  })();

  // FAQ
  document.querySelectorAll('.faq-q').forEach(q => {
    q.addEventListener('click', () => {
      const item = q.closest('.faq-item');
      const wasOpen = item.classList.contains('open');
      document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));
      if (!wasOpen) item.classList.add('open');
    });
  });

  // Register
  function handleRegister(e) {
    e.preventDefault();
    const btn = document.getElementById('regBtn');
    btn.textContent = 'Đang gửi...'; btn.disabled = true;
    const data = {
      name:  document.getElementById('reg-name').value,
      phone: document.getElementById('reg-phone').value,
      spa:   document.getElementById('reg-spa').value,
      city:  document.getElementById('reg-city').value,
    };
    fetch('/api/spa-register', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(data) })
      .catch(()=>{}).finally(()=>{
        document.getElementById('regForm').style.display = 'none';
        document.getElementById('regSuccess').style.display = 'block';
      });
  }

  // Scroll fade-in
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if(e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.08 });
  document.querySelectorAll('.fade-in').forEach(el => obs.observe(el));
</script>
</body>
</html>
