<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Nhà trọ quận 3 - Tự động hóa cho thuê phòng trọ</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Segoe UI', Arial, sans-serif; color: #333; overflow-x: hidden; }

    /* ── HERO ── */
    .hero {
      background: linear-gradient(135deg, #1a5c35 0%, #2c7a4b 50%, #38a169 100%);
      color: white; padding: 60px 20px 80px; text-align: center; position: relative;
    }
    .hero::after {
      content: ''; position: absolute; bottom: -1px; left: 0; right: 0; height: 60px;
      background: white; clip-path: ellipse(55% 100% at 50% 100%);
    }
    .hero .badge {
      display: inline-block; background: rgba(255,255,255,0.2); border: 1px solid rgba(255,255,255,0.4);
      padding: 6px 16px; border-radius: 20px; font-size: 13px; margin-bottom: 20px;
    }
    .hero h1 { font-size: clamp(28px, 5vw, 48px); font-weight: 800; line-height: 1.2; margin-bottom: 16px; }
    .hero h1 span { color: #86efac; }
    .hero p { font-size: clamp(15px, 2vw, 18px); opacity: 0.9; max-width: 560px; margin: 0 auto 32px; }
    .hero-btns { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
    .btn-hero { padding: 14px 28px; border-radius: 8px; font-size: 15px; font-weight: 600; text-decoration: none; cursor: pointer; border: none; }
    .btn-white { background: white; color: #2c7a4b; }
    .btn-white:hover { background: #f0faf5; }
    .btn-outline { background: transparent; color: white; border: 2px solid rgba(255,255,255,0.6); }
    .btn-outline:hover { background: rgba(255,255,255,0.1); }

    /* ── STATS ── */
    .stats { background: #f0faf5; padding: 40px 20px; }
    .stats-grid { max-width: 800px; margin: 0 auto; display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; text-align: center; }
    .stat-num { font-size: 36px; font-weight: 800; color: #2c7a4b; }
    .stat-label { font-size: 14px; color: #666; margin-top: 4px; }

    /* ── FEATURES ── */
    .features { padding: 70px 20px; background: white; }
    .section-title { text-align: center; margin-bottom: 50px; }
    .section-title h2 { font-size: clamp(22px, 3vw, 32px); font-weight: 800; color: #1a1a1a; }
    .section-title p { color: #666; margin-top: 10px; font-size: 16px; }

    .features-grid { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px; }
    .feature-card {
      border: 1px solid #e8e8e8; border-radius: 12px; padding: 28px;
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .feature-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.08); }
    .feature-icon { font-size: 36px; margin-bottom: 14px; }
    .feature-card h3 { font-size: 18px; font-weight: 700; margin-bottom: 8px; color: #1a1a1a; }
    .feature-card p { color: #666; font-size: 14px; line-height: 1.6; }

    /* ── HOW IT WORKS ── */
    .how { padding: 70px 20px; background: #f9f9f9; }
    .steps { max-width: 800px; margin: 0 auto; display: flex; flex-direction: column; gap: 0; }
    .step { display: flex; gap: 20px; align-items: flex-start; padding: 24px 0; border-bottom: 1px solid #eee; }
    .step:last-child { border-bottom: none; }
    .step-num {
      width: 44px; height: 44px; border-radius: 50%; background: #2c7a4b; color: white;
      font-size: 18px; font-weight: 800; display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .step-content h3 { font-size: 17px; font-weight: 700; margin-bottom: 6px; }
    .step-content p { color: #666; font-size: 14px; line-height: 1.6; }

    /* ── DEMO CHAT ── */
    .demo { padding: 70px 20px; background: #f9f9f9; }
    .demo-scenarios { max-width: 1080px; margin: 0 auto; display: grid; grid-template-columns: repeat(3,1fr); gap: 28px; }
    .scenario-card {
      background: white; border-radius: 20px; overflow: hidden;
      border: 1px solid #eee;
      box-shadow: 0 4px 20px rgba(0,0,0,.06);
      transition: transform .2s, box-shadow .2s;
    }
    .scenario-card:hover { transform: translateY(-6px); box-shadow: 0 16px 40px rgba(0,0,0,.12); }
    .scenario-header { padding: 18px 20px 14px; }
    .scenario-badge {
      display: inline-block; padding: 4px 12px; border-radius: 20px;
      font-size: 11px; font-weight: 700; margin-bottom: 10px;
    }
    .sb-1 { background: #dcfce7; color: #166534; }
    .sb-2 { background: #fef9c3; color: #854d0e; }
    .sb-3 { background: #ede9fe; color: #5b21b6; }
    .scenario-title { font-size: 15px; font-weight: 800; color: #1a1a1a; margin-bottom: 4px; }
    .scenario-sub   { font-size: 12px; color: #888; line-height: 1.5; }
    /* ── iPhone / Zalo mockup ── */
    .phone-wrap {
      display: flex; justify-content: center; align-items: center;
      background: linear-gradient(160deg, #1a5c35 0%, #2c7a4b 55%, #38a169 100%);
      padding: 20px 16px 24px;
    }
    .iphone {
      background: #1c1c1e; border-radius: 38px; padding: 8px;
      width: 188px;
      box-shadow: 0 0 0 1px #3a3a3c, 0 12px 32px rgba(0,0,0,.55);
      position: relative;
    }
    .iphone-screen { background: #ece5dd; border-radius: 32px; overflow: hidden; position: relative; }
    .dynamic-island {
      position: absolute; top: 7px; left: 50%; transform: translateX(-50%);
      width: 60px; height: 18px; background: #000; border-radius: 12px; z-index: 10;
    }
    .z-bar { background: #0068ff; color: white; padding: 28px 9px 7px; }
    .z-row { display: flex; align-items: center; gap: 6px; }
    .z-av {
      width: 22px; height: 22px; background: white; border-radius: 50%;
      display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .z-logo { font-size: 10px; font-weight: 900; font-style: italic; color: #0068ff; }
    .z-name { font-size: 10px; font-weight: 700; }
    .z-sub  { font-size: 7.5px; opacity: .8; }
    .z-body { background: #f0f2f5; padding: 7px; display: flex; flex-direction: column; gap: 5px; min-height: 190px; }
    .zm { max-width: 88%; padding: 5px 8px; font-size: 9.5px; line-height: 1.45; border-radius: 7px; }
    .zmb { background: white; align-self: flex-start; border-radius: 2px 7px 7px 7px; box-shadow: 0 1px 2px rgba(0,0,0,.07); }
    .zmu { background: #d9f2ff; color: #003d99; align-self: flex-end; border-radius: 7px 2px 7px 7px; }
    .zmt { font-size: 7.5px; color: #aaa; margin-top: 2px; }
    .zmbtns { display: flex; flex-wrap: wrap; gap: 3px; margin-top: 4px; }
    .zmbtn { background: #e8f4ee; border: 1px solid #2c7a4b; color: #1a5c35; padding: 2px 6px; border-radius: 7px; font-size: 8.5px; font-weight: 600; }
    .zm-ai { background: #f0f9ff; align-self: flex-start; border-radius: 2px 7px 7px 7px; box-shadow: 0 1px 2px rgba(0,0,0,.07); border-left: 2px solid #2c7a4b; }
    @media (max-width: 960px) { .demo-scenarios { grid-template-columns: 1fr; max-width: 380px; } }

    /* ── PRICING ── */
    .pricing { padding: 70px 20px; background: #f9f9f9; }
    .pricing-grid { max-width: 1060px; margin: 0 auto; display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; align-items: start; }
    .price-card { background: white; border-radius: 16px; padding: 0; border: 2px solid #eee; overflow: hidden; transition: transform .2s, box-shadow .2s; }
    .price-card:hover { transform: translateY(-5px); box-shadow: 0 16px 40px rgba(0,0,0,.1); }
    .price-card.featured { border-color: #2c7a4b; box-shadow: 0 8px 32px rgba(44,122,75,.18); }
    .price-card.featured:hover { transform: scale(1.02) translateY(-5px); }
    .price-card.elite { border-color: #5b21b6; }
    .price-top { padding: 26px 24px 20px; }
    .price-badge { display: inline-block; padding: 4px 12px; border-radius: 20px; font-size: 11px; font-weight: 700; margin-bottom: 12px; }
    .badge-basic    { background: #f1f5f9; color: #475569; }
    .badge-featured { background: #d1fae5; color: #065f46; }
    .badge-elite    { background: #ede9fe; color: #5b21b6; }
    .price-name { font-size: 20px; font-weight: 800; color: #1a1a1a; margin-bottom: 6px; }
    .price-name.ai-name   { color: #2c7a4b; }
    .price-name.pro-name  { color: #5b21b6; }
    .price-amount { font-size: 38px; font-weight: 900; color: #1a1a1a; line-height: 1; }
    .price-amount span { font-size: 14px; color: #888; font-weight: 400; }
    .price-desc { color: #888; font-size: 13px; margin: 6px 0 0; }
    .price-divider { height: 1px; background: #eee; margin: 0 24px; }
    .price-features { list-style: none; display: flex; flex-direction: column; gap: 9px; padding: 20px 24px 24px; }
    .price-features li { font-size: 14px; color: #555; display: flex; align-items: flex-start; gap: 8px; line-height: 1.45; }
    .price-features li::before { content: '✓'; color: #2c7a4b; font-weight: 700; flex-shrink: 0; margin-top: 1px; }
    .price-features li.purple::before { content: '✦'; color: #7c3aed; }
    .price-cta { padding: 0 24px 26px; }
    .btn-price { display: block; text-align: center; padding: 13px; border-radius: 10px; font-weight: 700; font-size: 14px; text-decoration: none; }
    .btn-green { background: #2c7a4b; color: white; }
    .btn-green:hover { background: #235e3a; }
    .btn-gray { background: #f0f0f0; color: #333; }
    .btn-gray:hover { background: #e0e0e0; }
    .btn-purple { background: #1e1b4b; color: white; }
    .btn-purple:hover { background: #312e81; }

    /* ── CTA ── */
    .cta { background: linear-gradient(135deg, #1a5c35, #2c7a4b); color: white; padding: 70px 20px; text-align: center; }
    .cta h2 { font-size: clamp(22px, 3vw, 36px); font-weight: 800; margin-bottom: 16px; }
    .cta p { opacity: 0.9; font-size: 16px; margin-bottom: 32px; }
    .cta-btns { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }

    /* ── FOOTER ── */
    footer { background: #1a1a1a; color: #999; padding: 30px 20px; text-align: center; font-size: 14px; }
    footer a { color: #86efac; text-decoration: none; }

    /* ── RESPONSIVE ── */
    @media (max-width: 960px) {
      .pricing-grid { grid-template-columns: 1fr; max-width: 420px; }
    }
    @media (max-width: 768px) {
      .stats-grid { grid-template-columns: repeat(3, 1fr); gap: 12px; }
      .stat-num { font-size: 26px; }
      .demo-container { grid-template-columns: 1fr; }
      .hero-btns { flex-direction: column; align-items: center; }
      .btn-hero { width: 100%; max-width: 280px; text-align: center; }
    }
  </style>
</head>
<body>

<!-- HERO -->
<section class="hero">
  <div class="badge">🚀 Giải pháp cho thuê phòng trọ thông minh</div>
  <h1>Trợ lý ảo tự động cho<br><span>phòng trọ của bạn</span></h1>
  <p>Tự động trả lời khách hỏi 24/7, quản lý phòng trống, nhận đặt lịch xem phòng — tất cả qua Telegram & Zalo</p>
  <div class="hero-btns">
    <a href="/admin" class="btn-hero btn-white">🏠 Quản lý phòng trọ</a>
    <a href="#demo" class="btn-hero btn-outline">Xem demo</a>
  </div>
</section>

<!-- STATS -->
<section class="stats">
  <div class="stats-grid">
    <div>
      <div class="stat-num">24/7</div>
      <div class="stat-label">Tự động trả lời</div>
    </div>
    <div>
      <div class="stat-num">0đ</div>
      <div class="stat-label">Miễn phí hoàn toàn</div>
    </div>
    <div>
      <div class="stat-num">3</div>
      <div class="stat-label">Loại trợ lý ảo</div>
    </div>
  </div>
</section>

<!-- FEATURES -->
<section class="features">
  <div class="section-title">
    <h2>Tính năng nổi bật</h2>
    <p>Mọi thứ bạn cần để quản lý phòng trọ hiệu quả hơn</p>
  </div>
  <div class="features-grid">
    <div class="feature-card">
      <div class="feature-icon">🤖</div>
      <h3>Tự động trả lời 24/7</h3>
      <p>Trợ lý ảo tự động trả lời mọi câu hỏi của khách thuê về giá phòng, diện tích, khu vực — kể cả khi bạn đang ngủ.</p>
    </div>
    <div class="feature-card">
      <div class="feature-icon">📸</div>
      <h3>Hiển thị ảnh phòng</h3>
      <p>Gửi ảnh phòng trực tiếp qua trợ lý ảo khi khách hỏi. Khách xem ảnh đẹp, quyết định nhanh hơn.</p>
    </div>
    <div class="feature-card">
      <div class="feature-icon">🔍</div>
      <h3>Tìm phòng theo giá</h3>
      <p>Khách nhập ngân sách, trợ lý ảo tự lọc và gợi ý các phòng phù hợp trong tích tắc.</p>
    </div>
    <div class="feature-card">
      <div class="feature-icon">📋</div>
      <h3>Quản lý dễ dàng</h3>
      <p>Trang quản trị đơn giản để thêm/xóa phòng, cập nhật trạng thái, upload ảnh chỉ vài click.</p>
    </div>
    <div class="feature-card">
      <div class="feature-icon">💬</div>
      <h3>Telegram & Zalo</h3>
      <p>Hỗ trợ cả Telegram và Zalo — 2 nền tảng phổ biến nhất tại Việt Nam.</p>
    </div>
    <div class="feature-card">
      <div class="feature-icon">☁️</div>
      <h3>Chạy 24/7 trên cloud</h3>
      <p>Deploy trên Railway, trợ lý ảo hoạt động liên tục không cần bạn bật máy tính.</p>
    </div>
  </div>
</section>

<!-- HOW IT WORKS -->
<section class="how">
  <div class="section-title">
    <h2>Hoạt động như thế nào?</h2>
    <p>Chỉ 3 bước đơn giản để bắt đầu</p>
  </div>
  <div class="steps">
    <div class="step">
      <div class="step-num">1</div>
      <div class="step-content">
        <h3>Thêm phòng trọ vào hệ thống</h3>
        <p>Đăng nhập trang quản trị, nhập thông tin phòng (giá, địa chỉ, diện tích) và upload ảnh. Chỉ mất 2 phút mỗi phòng.</p>
      </div>
    </div>
    <div class="step">
      <div class="step-num">2</div>
      <div class="step-content">
        <h3>Chia sẻ link trợ lý ảo cho khách thuê</h3>
        <p>Gửi link Telegram hoặc Zalo trợ lý ảo cho khách. Họ có thể tự tra cứu thông tin phòng bất kỳ lúc nào.</p>
      </div>
    </div>
    <div class="step">
      <div class="step-num">3</div>
      <div class="step-content">
        <h3>Trợ lý ảo tự động xử lý, bạn chỉ chốt đơn</h3>
        <p>Trợ lý ảo trả lời câu hỏi, giới thiệu phòng, cung cấp SĐT liên hệ. Bạn chỉ cần gặp khách khi họ muốn xem phòng thật.</p>
      </div>
    </div>
  </div>
</section>

<!-- DEMO CHAT -->
<section class="demo" id="demo">
  <div class="section-title">
    <h2>Xem trợ lý ảo AI hoạt động</h2>
    <p>3 tình huống thực tế — trợ lý ảo xử lý thông minh, chủ trọ không cần trực</p>
  </div>
  <div class="demo-scenarios">

    <!-- TÌNH HUỐNG 1: AI hiểu ngôn ngữ tự nhiên -->
    <div class="scenario-card">
      <div class="scenario-header">
        <div class="scenario-badge sb-1">🧠 AI hiểu tiếng tự nhiên</div>
        <div class="scenario-title">Khách nhắn kiểu gì cũng hiểu</div>
        <div class="scenario-sub">Không cần bấm menu — nhắn thoải mái như nói chuyện</div>
      </div>
      <div class="phone-wrap">
        <div class="iphone">
          <div class="iphone-screen">
            <div class="dynamic-island"></div>
            <div class="z-bar">
              <div class="z-row">
                <div class="z-av"><div class="z-logo">Z</div></div>
                <div>
                  <div class="z-name">🏠 Nhà trọ quận 3</div>
                  <div class="z-sub">🟢 Đang hoạt động</div>
                </div>
              </div>
            </div>
            <div class="z-body">
              <div class="zm zmu">mình cần phòng tầm 2-3tr, có chỗ để xe máy, gần chợ<div class="zmt" style="text-align:right">10:05</div></div>
              <div class="zm zm-ai">
                ✨ Hiểu rồi! Mình tìm phòng cho bạn:<br><br>
                🏠 <b>Phòng 201</b> — 2.500.000đ<br>
                📍 Cách chợ Q.3 chỉ 300m<br>
                🛵 Bãi xe máy miễn phí · 22m²<br>
                ✅ Còn trống
                <div class="zmbtns">
                  <span class="zmbtn">📸 Xem ảnh</span>
                  <span class="zmbtn">📅 Đặt lịch xem</span>
                </div>
                <div class="zmt">10:05</div>
              </div>
              <div class="zm zmu">phòng có wifi ko bạn<div class="zmt" style="text-align:right">10:06</div></div>
              <div class="zm zm-ai">
                Dạ có! Phòng 201 bao gồm:<br>
                📶 WiFi tốc độ cao miễn phí<br>
                💡 Điện nước sinh hoạt<br>
                🔒 Khóa cửa thẻ từ
                <div class="zmt">10:06</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- TÌNH HUỐNG 2: Trả lời 2h sáng -->
    <div class="scenario-card">
      <div class="scenario-header">
        <div class="scenario-badge sb-2">🌙 Hoạt động 24/7</div>
        <div class="scenario-title">2h sáng khách hỏi — vẫn trả lời ngay</div>
        <div class="scenario-sub">Chủ trọ ngủ ngon, khách vẫn được hỗ trợ tức thì</div>
      </div>
      <div class="phone-wrap">
        <div class="iphone">
          <div class="iphone-screen">
            <div class="dynamic-island"></div>
            <div class="z-bar">
              <div class="z-row">
                <div class="z-av"><div class="z-logo">Z</div></div>
                <div>
                  <div class="z-name">🏠 Nhà trọ quận 3</div>
                  <div class="z-sub">🟢 Đang hoạt động</div>
                </div>
              </div>
            </div>
            <div class="z-body">
              <div class="zm zmu">mai mình muốn xem phòng được không ạ<div class="zmt" style="text-align:right">02:14</div></div>
              <div class="zm zm-ai">
                Dạ được bạn ơi! 🌙<br>
                Lịch xem phòng ngày mai:<br><br>
                🕗 Sáng: 8:00 – 11:30<br>
                🕑 Chiều: 14:00 – 17:30<br><br>
                Bạn chọn khung giờ nào?
                <div class="zmbtns">
                  <span class="zmbtn">8:00</span>
                  <span class="zmbtn">9:30</span>
                  <span class="zmbtn">14:00</span>
                  <span class="zmbtn">15:30</span>
                </div>
                <div class="zmt">02:14</div>
              </div>
              <div class="zm zmu">9:30 sáng nha<div class="zmt" style="text-align:right">02:15</div></div>
              <div class="zm zm-ai">
                ✅ Đặt lịch thành công!<br>
                📅 Ngày mai · 9:30 sáng<br>
                📍 123 Lý Tự Trọng, Q.3<br>
                🔔 Mình sẽ nhắc bạn lúc 9:00
                <div class="zmt">02:15</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- TÌNH HUỐNG 3: Xử lý thương lượng giá khéo -->
    <div class="scenario-card">
      <div class="scenario-header">
        <div class="scenario-badge sb-3">💬 Thương lượng thông minh</div>
        <div class="scenario-title">Giữ giá khéo, không mất khách</div>
        <div class="scenario-sub">AI trả lời thuyết phục, giới thiệu thêm giá trị phòng</div>
      </div>
      <div class="phone-wrap">
        <div class="iphone">
          <div class="iphone-screen">
            <div class="dynamic-island"></div>
