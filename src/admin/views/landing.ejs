</section>

<!-- STATS -->
<section class="stats">
  <div class="stats-grid">
    <div>
      <div class="stat-num">24/7</div>
      <div class="stat-label">Tự động trả lời</div>
    </div>
    <div>
      <div class="stat-num">0đ</div>
      <div class="stat-label">Miễn phí hoàn toàn</div>
