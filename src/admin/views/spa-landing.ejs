  </div>
  <div class="demo-cta">
    <a href="#contact">💬 Tôi muốn dùng thử miễn phí</a>
  </div>
</section>

<!-- PLANS -->
<section class="plans-sec" id="plans">
  <div class="sec-label">Gói dịch vụ</div>
  <div class="sec-title">Chọn gói phù hợp với spa</div>

  <div class="plans">

    <!-- BOT CƠ BẢN -->
    <div class="plan">
      <div class="plan-head">
