<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Spa Joliecao Beauty - Bot Đặt Lịch Thông Minh</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Segoe UI', Arial, sans-serif; color: #333; overflow-x: hidden; }

    /* ── COLORS ── */
    :root {
      --primary: #8b7355;
      --primary-dark: #6b5640;
      --primary-light: #f5f0eb;
      --accent: #c9a96e;
      --text: #3a3a3a;
      --gray: #f7f5f2;
    }

    /* ── NAV ── */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      background: rgba(255,255,255,0.95); backdrop-filter: blur(10px);
      padding: 14px 32px; display: flex; justify-content: space-between; align-items: center;
      box-shadow: 0 1px 12px rgba(0,0,0,0.06);
    }
    .nav-logo { font-size: 18px; font-weight: 700; color: var(--primary); letter-spacing: 0.5px; }
    .nav-logo span { color: var(--accent); }
    .nav-btn {
      background: var(--primary); color: white; padding: 9px 20px;
      border-radius: 6px; font-size: 14px; font-weight: 600; text-decoration: none;
    }
    .nav-btn:hover { background: var(--primary-dark); }

    /* ── HERO ── */
    .hero {
      padding: 120px 20px 90px; text-align: center;
      background: linear-gradient(160deg, #fdfcfa 0%, #f5f0eb 50%, #ede5d8 100%);
      position: relative; overflow: hidden;
    }
    .hero::before {
      content: '✦'; position: absolute; top: 80px; left: 8%; font-size: 40px;
      color: var(--accent); opacity: 0.3; animation: float 4s ease-in-out infinite;
    }
    .hero::after {
      content: '✦'; position: absolute; bottom: 80px; right: 8%; font-size: 28px;
      color: var(--accent); opacity: 0.2; animation: float 5s ease-in-out infinite reverse;
    }
    @keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-12px)} }

    .hero-tag {
      display: inline-block; background: white; border: 1px solid var(--accent);
      color: var(--primary); padding: 6px 18px; border-radius: 20px;
      font-size: 13px; font-weight: 500; margin-bottom: 24px; letter-spacing: 0.5px;
    }
    .hero h1 {
      font-size: clamp(30px, 5vw, 54px); font-weight: 800; color: var(--text);
      line-height: 1.15; margin-bottom: 20px;
    }
    .hero h1 em { color: var(--primary); font-style: normal; }
    .hero p {
      font-size: clamp(15px, 2vw, 18px); color: #666; max-width: 580px;
      margin: 0 auto 36px; line-height: 1.7;
    }
    .hero-btns { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
    .btn-main {
      padding: 14px 30px; border-radius: 8px; font-size: 15px; font-weight: 600;
      text-decoration: none; display: inline-flex; align-items: center; gap: 8px;
    }
    .btn-solid { background: var(--primary); color: white; }
    .btn-solid:hover { background: var(--primary-dark); }
    .btn-border { border: 2px solid var(--primary); color: var(--primary); background: white; }
    .btn-border:hover { background: var(--primary-light); }

    .hero-badges { display: flex; gap: 20px; justify-content: center; margin-top: 40px; flex-wrap: wrap; }
    .badge-item { display: flex; align-items: center; gap: 6px; font-size: 13px; color: #777; }
    .badge-item::before { content: '✓'; color: var(--accent); font-weight: 700; }

    /* ── STATS ── */
    .stats { background: var(--primary); color: white; padding: 50px 20px; }
    .stats-grid { max-width: 800px; margin: 0 auto; display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; text-align: center; }
    .stat-num { font-size: 34px; font-weight: 800; color: var(--accent); }
    .stat-label { font-size: 13px; opacity: 0.85; margin-top: 4px; }

    /* ── FEATURES ── */
    .features { padding: 80px 20px; background: white; }
    .section-label { text-align: center; color: var(--accent); font-size: 13px; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 12px; }
    .section-title { text-align: center; font-size: clamp(22px, 3vw, 34px); font-weight: 800; color: var(--text); margin-bottom: 10px; }
    .section-sub { text-align: center; color: #888; margin-bottom: 50px; font-size: 15px; }

    .features-grid { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 24px; }
    .feature-card {
      background: var(--gray); border-radius: 14px; padding: 30px;
      transition: transform 0.2s, box-shadow 0.2s; border: 1px solid #ede8e0;
    }
    .feature-card:hover { transform: translateY(-5px); box-shadow: 0 16px 40px rgba(139,115,85,0.12); }
    .feature-icon { width: 52px; height: 52px; background: white; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 24px; margin-bottom: 18px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
    .feature-card h3 { font-size: 17px; font-weight: 700; color: var(--text); margin-bottom: 8px; }
    .feature-card p { color: #777; font-size: 14px; line-height: 1.65; }

    /* ── HOW IT WORKS ── */
    .how { padding: 80px 20px; background: var(--gray); }
    .steps-grid { max-width: 900px; margin: 0 auto; display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 0; position: relative; }
    .steps-grid::before {
      content: ''; position: absolute; top: 32px; left: 15%; right: 15%; height: 2px;
      background: linear-gradient(90deg, var(--accent), var(--primary)); opacity: 0.3;
    }
    .step { text-align: center; padding: 20px 16px; position: relative; }
    .step-circle {
      width: 64px; height: 64px; border-radius: 50%; background: white; border: 2px solid var(--accent);
      display: flex; align-items: center; justify-content: center; margin: 0 auto 16px;
      font-size: 24px; box-shadow: 0 4px 16px rgba(139,115,85,0.15); position: relative; z-index: 1;
    }
    .step h3 { font-size: 15px; font-weight: 700; margin-bottom: 6px; color: var(--text); }
    .step p { font-size: 13px; color: #888; line-height: 1.5; }

    /* ── DEMO CHAT ── */
    .demo { padding: 80px 20px; background: white; }
    .demo-wrap { max-width: 1050px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
    .demo-info h2 { font-size: clamp(22px, 2.5vw, 30px); font-weight: 800; color: var(--text); margin-bottom: 16px; line-height: 1.3; }
    .demo-info p { color: #777; line-height: 1.7; font-size: 15px; margin-bottom: 20px; }
    .check-list { list-style: none; display: flex; flex-direction: column; gap: 12px; }
    .check-list li { display: flex; align-items: flex-start; gap: 10px; font-size: 14px; color: #555; }
    .check-list li .ck { width: 22px; height: 22px; background: var(--primary-light); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--primary); font-size: 12px; flex-shrink: 0; margin-top: 1px; }

    .phone-mockup {
      background: #1a1a1a; border-radius: 36px; padding: 12px;
      box-shadow: 0 24px 60px rgba(0,0,0,0.2); max-width: 300px; margin: 0 auto;
    }
    .phone-screen { background: #f0f0f0; border-radius: 26px; overflow: hidden; }
    .phone-header { background: var(--primary); color: white; padding: 14px 16px; display: flex; align-items: center; gap: 10px; }
    .phone-avatar { width: 34px; height: 34px; background: rgba(255,255,255,0.25); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 16px; }
    .phone-name { font-size: 14px; font-weight: 600; }
    .phone-status { font-size: 11px; opacity: 0.8; }
    .phone-body { padding: 12px; display: flex; flex-direction: column; gap: 8px; background: #ece5dd; min-height: 320px; }
    .pm { max-width: 82%; padding: 8px 12px; font-size: 12px; line-height: 1.5; border-radius: 8px; }
    .pm.b { background: white; color: #333; align-self: flex-start; border-radius: 2px 8px 8px 8px; }
    .pm.u { background: #dcf8c6; color: #333; align-self: flex-end; border-radius: 8px 2px 8px 8px; }
    .pm-time { font-size: 10px; color: #aaa; margin-top: 2px; }
    .pm-btns { display: flex; flex-wrap: wrap; gap: 4px; margin-top: 6px; }
    .pm-btn { background: var(--primary-light); border: 1px solid var(--accent); color: var(--primary); padding: 4px 8px; border-radius: 12px; font-size: 11px; }

    /* ── PLATFORMS ── */
    .platforms { padding: 70px 20px; background: var(--gray); }
    .platform-cards { max-width: 700px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    .platform-card { background: white; border-radius: 14px; padding: 28px; text-align: center; border: 1px solid #ede8e0; }
    .platform-icon { font-size: 40px; margin-bottom: 12px; }
    .platform-card h3 { font-size: 17px; font-weight: 700; margin-bottom: 8px; color: var(--text); }
    .platform-card p { font-size: 13px; color: #888; line-height: 1.6; }

    /* ── PRICING ── */
    .pricing { padding: 80px 20px; background: white; }
    .pricing-grid { max-width: 750px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
    .price-card { border-radius: 14px; padding: 30px; border: 2px solid #ede8e0; }
    .price-card.hot { border-color: var(--accent); position: relative; }
    .hot-badge {
      position: absolute; top: -13px; left: 50%; transform: translateX(-50%);
      background: var(--accent); color: white; padding: 4px 16px;
      border-radius: 12px; font-size: 12px; font-weight: 600; white-space: nowrap;
    }
    .price-name { font-size: 14px; color: #999; font-weight: 600; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 1px; }
    .price-val { font-size: 38px; font-weight: 800; color: var(--text); }
    .price-val span { font-size: 15px; font-weight: 400; color: #999; }
    .price-note { font-size: 13px; color: #bbb; margin: 6px 0 20px; }
    .price-list { list-style: none; display: flex; flex-direction: column; gap: 9px; margin-bottom: 26px; }
    .price-list li { font-size: 13px; color: #666; display: flex; align-items: center; gap: 8px; }
    .price-list li::before { content: '✓'; color: var(--accent); font-weight: 700; }
    .price-cta { display: block; text-align: center; padding: 12px; border-radius: 8px; font-weight: 600; font-size: 14px; text-decoration: none; }
    .cta-solid { background: var(--primary); color: white; }
    .cta-solid:hover { background: var(--primary-dark); }
    .cta-light { background: var(--primary-light); color: var(--primary); }
    .cta-light:hover { background: #ede5d8; }

    /* ── CTA ── */
    .cta-section {
      padding: 80px 20px; text-align: center;
      background: linear-gradient(135deg, var(--primary-dark), var(--primary), #a08060);
      color: white; position: relative; overflow: hidden;
    }
    .cta-section::before { content: '✦'; position: absolute; top: 30px; left: 10%; font-size: 50px; opacity: 0.1; }
    .cta-section::after { content: '✦'; position: absolute; bottom: 30px; right: 10%; font-size: 35px; opacity: 0.1; }
    .cta-section h2 { font-size: clamp(24px, 3vw, 38px); font-weight: 800; margin-bottom: 14px; }
    .cta-section p { opacity: 0.85; font-size: 16px; margin-bottom: 36px; }
    .cta-btns { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
    .btn-cta-w { background: white; color: var(--primary); padding: 14px 28px; border-radius: 8px; font-weight: 700; font-size: 15px; text-decoration: none; }
    .btn-cta-w:hover { background: #f5f0eb; }
    .btn-cta-o { border: 2px solid rgba(255,255,255,0.6); color: white; padding: 14px 28px; border-radius: 8px; font-weight: 600; font-size: 15px; text-decoration: none; }
    .btn-cta-o:hover { background: rgba(255,255,255,0.1); }

    /* ── FOOTER ── */
    footer { background: #2a2218; color: #888; padding: 30px 20px; text-align: center; font-size: 13px; }
    footer strong { color: var(--accent); }

    /* ── RESPONSIVE ── */
    @media (max-width: 768px) {
      nav { padding: 12px 16px; }
      .stats-grid { grid-template-columns: repeat(2, 1fr); }
      .steps-grid::before { display: none; }
      .demo-wrap { grid-template-columns: 1fr; }
      .platform-cards { grid-template-columns: 1fr; }
      .pricing-grid { grid-template-columns: 1fr; }
      .hero-btns { flex-direction: column; align-items: center; }
      .btn-main { width: 100%; max-width: 280px; justify-content: center; }
      .phone-mockup { max-width: 260px; }
    }
  </style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="nav-logo">✦ <span>Joliecao</span> Beauty</div>
