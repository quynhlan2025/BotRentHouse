<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Giải pháp Trợ lý AI Spa – Chọn gói phù hợp</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --p:  #8b7355; --pd: #6b5640; --pl: #f5f0eb;
      --a:  #c9a96e; --bg: #faf9f7; --text: #2d2d2d;
      --basic: #64748b; --ai: #8b7355; --pro: #6d28d9;
    }
    body { font-family: 'Segoe UI', Arial, sans-serif; color: var(--text); background: var(--bg); overflow-x: hidden; }

    /* NAV */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      background: rgba(255,255,255,.95); backdrop-filter: blur(10px);
      padding: 14px 32px; display: flex; justify-content: space-between; align-items: center;
      box-shadow: 0 1px 10px rgba(0,0,0,.06);
    }
    .logo { font-size: 17px; font-weight: 700; color: var(--p); }
    .logo span { color: var(--a); }
    .nav-links { display: flex; gap: 24px; }
    .nav-links a { font-size: 14px; color: #666; text-decoration: none; }
    .nav-links a:hover { color: var(--p); }
    .nav-cta { background: var(--p); color: white; padding: 9px 20px; border-radius: 7px; font-size: 13px; font-weight: 600; text-decoration: none; }

    /* HERO */
    .hero {
      padding: 110px 20px 64px; text-align: center;
      background: linear-gradient(160deg, #fdfcfa 0%, #f5f0eb 60%, #ede5d8 100%);
    }
    .tag { display: inline-block; border: 1px solid var(--a); color: var(--p); padding: 5px 18px; border-radius: 20px; font-size: 13px; margin-bottom: 20px; }
    .hero h1 { font-size: clamp(28px, 5vw, 52px); font-weight: 800; line-height: 1.15; margin-bottom: 16px; }
    .hero h1 em { color: var(--p); font-style: normal; }
    .hero p { font-size: 16px; color: #666; max-width: 520px; margin: 0 auto 14px; line-height: 1.7; }
    .hero-note { font-size: 13px; color: #aaa; }

    /* SECTION */
    .sec { padding: 72px 20px; }
    .sec.white { background: white; }
    .sec.gray  { background: var(--bg); }
    .sec-label { text-align: center; color: var(--a); font-size: 12px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 10px; }
    .sec-title { text-align: center; font-size: clamp(22px, 3vw, 34px); font-weight: 800; margin-bottom: 10px; }
    .sec-sub   { text-align: center; color: #888; font-size: 15px; margin-bottom: 52px; }

    /* PLANS GRID */
    .plans { max-width: 1060px; margin: 0 auto; display: grid; grid-template-columns: repeat(3,1fr); gap: 24px; align-items: start; }

    .plan {
      border-radius: 18px; border: 2px solid #ede8e0;
      overflow: hidden; background: white; transition: transform .2s, box-shadow .2s;
    }
    .plan:hover { transform: translateY(-6px); box-shadow: 0 20px 50px rgba(0,0,0,.1); }
    .plan.featured { border-color: var(--p); transform: scale(1.03); box-shadow: 0 16px 48px rgba(139,115,85,.2); }
    .plan.featured:hover { transform: scale(1.03) translateY(-6px); }
    .plan.pro-plan { border-color: var(--pro); }

    .plan-header { padding: 28px 26px 22px; }
    .plan-badge {
      display: inline-block; padding: 3px 12px; border-radius: 20px;
      font-size: 11px; font-weight: 700; letter-spacing: .5px; margin-bottom: 14px;
    }
    .badge-basic { background: #f1f5f9; color: var(--basic); }
    .badge-ai    { background: var(--pl); color: var(--p); }
    .badge-pro   { background: #ede9fe; color: var(--pro); }

    .plan-name { font-size: 20px; font-weight: 800; margin-bottom: 6px; }
    .plan-name.basic { color: var(--basic); }
    .plan-name.ai    { color: var(--p); }
    .plan-name.pro   { color: var(--pro); }

    .plan-desc { font-size: 13px; color: #888; line-height: 1.6; margin-bottom: 20px; }
    .plan-price { font-size: 36px; font-weight: 800; color: var(--text); }
    .plan-price span { font-size: 14px; font-weight: 400; color: #aaa; }
    .plan-price-note { font-size: 12px; color: #bbb; margin-top: 4px; }

    .plan-divider { height: 1px; background: #f0ece6; margin: 0 26px; }

    .plan-features { padding: 22px 26px 28px; display: flex; flex-direction: column; gap: 11px; }
    .feat { display: flex; align-items: flex-start; gap: 10px; font-size: 13.5px; color: #444; }
    .feat .ic { flex-shrink: 0; width: 20px; height: 20px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 11px; margin-top: 1px; }
    .ic-basic { background: #f1f5f9; color: var(--basic); }
    .ic-ai    { background: var(--pl); color: var(--p); }
    .ic-pro   { background: #ede9fe; color: var(--pro); }
    .feat .label { line-height: 1.5; }
    .feat .label small { display: block; font-size: 11.5px; color: #aaa; margin-top: 1px; }
    .feat-new { background: #fff7ed; color: #c2410c; font-size: 10px; font-weight: 700; padding: 1px 7px; border-radius: 8px; margin-left: 6px; vertical-align: middle; }

    .plan-cta { padding: 0 26px 28px; }
    .btn-plan {
      display: block; text-align: center; padding: 13px; border-radius: 9px;
      font-weight: 700; font-size: 14px; text-decoration: none; transition: opacity .15s;
    }
    .btn-plan:hover { opacity: .85; }
    .btn-basic { background: #f1f5f9; color: var(--basic); }
    .btn-ai    { background: var(--p);  color: white; }
    .btn-pro   { background: var(--pro); color: white; }

    /* FEATURE TABLE */
    .compare { max-width: 900px; margin: 0 auto; }
    .compare table { width: 100%; border-collapse: collapse; font-size: 14px; }
    .compare thead th { padding: 14px 20px; font-size: 13px; font-weight: 700; text-align: center; border-bottom: 2px solid #ede8e0; }
    .compare thead th:first-child { text-align: left; color: #888; font-weight: 600; }
    .compare thead .th-basic { color: var(--basic); }
    .compare thead .th-ai    { color: var(--p); }
    .compare thead .th-pro   { color: var(--pro); }
    .compare tbody tr { border-bottom: 1px solid #f0ece6; transition: background .1s; }
    .compare tbody tr:hover { background: #fdf9f5; }
    .compare td { padding: 13px 20px; }
    .compare td:not(:first-child) { text-align: center; }
    .compare .cat-row td { background: #faf9f7; font-size: 12px; font-weight: 700; color: #aaa; text-transform: uppercase; letter-spacing: 1px; padding: 10px 20px; }
    .ck-y { color: #16a34a; font-size: 18px; }
    .ck-n { color: #d1d5db; font-size: 18px; }
    .ck-p { color: var(--pro); font-size: 18px; }

    /* DEMO CHAT ROW */
    .demos { max-width: 1060px; margin: 0 auto; display: grid; grid-template-columns: repeat(3,1fr); gap: 24px; }
    .demo-card { background: white; border-radius: 16px; border: 1px solid #ede8e0; overflow: hidden; }
    .demo-card-header { padding: 16px 18px; font-size: 14px; font-weight: 700; display: flex; align-items: center; gap: 8px; }
    .demo-card-header.basic { background: #f8fafc; color: var(--basic); border-bottom: 1px solid #e2e8f0; }
    .demo-card-header.ai    { background: var(--pl); color: var(--p); border-bottom: 1px solid #e8ddd0; }
    .demo-card-header.pro   { background: #f5f3ff; color: var(--pro); border-bottom: 1px solid #ddd6fe; }
    .chat { padding: 12px; background: #ece5dd; display: flex; flex-direction: column; gap: 7px; min-height: 260px; }
    .m { max-width: 88%; padding: 8px 11px; font-size: 12px; line-height: 1.5; border-radius: 8px; }
    .mb { background: white; align-self: flex-start; border-radius: 2px 8px 8px 8px; }
    .mu { background: #dcf8c6; align-self: flex-end; border-radius: 8px 2px 8px 8px; }
    .mt { font-size: 10px; color: #aaa; margin-top: 2px; }
    .mbtns { display: flex; flex-wrap: wrap; gap: 4px; margin-top: 6px; }
    .mbtn-basic { background: #f1f5f9; border: 1px solid #cbd5e1; color: var(--basic); padding: 3px 8px; border-radius: 10px; font-size: 11px; }
    .mbtn-ai    { background: var(--pl); border: 1px solid var(--a); color: var(--p); padding: 3px 8px; border-radius: 10px; font-size: 11px; }
    .mbtn-pro   { background: #ede9fe; border: 1px solid #c4b5fd; color: var(--pro); padding: 3px 8px; border-radius: 10px; font-size: 11px; }
    .ai-typing  { display: flex; align-items: center; gap: 4px; padding: 8px 12px; background: white; border-radius: 2px 8px 8px 8px; align-self: flex-start; width: fit-content; }
    .dot { width: 6px; height: 6px; border-radius: 50%; background: #aaa; animation: bounce .8s infinite; }
    .dot:nth-child(2) { animation-delay: .15s; }
    .dot:nth-child(3) { animation-delay: .3s; }
    @keyframes bounce { 0%,80%,100%{transform:translateY(0)} 40%{transform:translateY(-5px)} }

    /* CTA */
    .cta {
      padding: 72px 20px; text-align: center;
      background: linear-gradient(135deg, var(--pd), var(--p), #a08060); color: white;
    }
    .cta h2 { font-size: clamp(22px, 3vw, 36px); font-weight: 800; margin-bottom: 12px; }
    .cta p  { opacity: .85; font-size: 15px; margin-bottom: 32px; }
    .cta-btns { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
    .btn-w { background: white; color: var(--p); padding: 13px 28px; border-radius: 8px; font-weight: 700; font-size: 14px; text-decoration: none; }
    .btn-o { border: 2px solid rgba(255,255,255,.6); color: white; padding: 13px 28px; border-radius: 8px; font-weight: 600; font-size: 14px; text-decoration: none; }

    footer { background: #2a2218; color: #777; padding: 26px 20px; text-align: center; font-size: 13px; }
    footer strong { color: var(--a); }

    @media (max-width: 900px) {
      .plans, .demos { grid-template-columns: 1fr; }
      .plan.featured { transform: none; }
      nav .nav-links { display: none; }
    }
    @media (max-width: 680px) {
      .compare { overflow-x: auto; }
    }
  </style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="logo">✦ <span>Joliecao</span> Beauty</div>
  <div class="nav-links">
    <a href="#plans">Gói trợ lý</a>
    <a href="#compare">So sánh</a>
    <a href="#demo">Demo</a>
  </div>
  <a href="#contact" class="nav-cta">Tư vấn miễn phí</a>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="tag">🤖 3 cấp độ trợ lý — chọn đúng nhu cầu</div>
  <h1>Trợ lý AI từ <em>cơ bản</em><br>đến <em>AI thông minh nhất</em></h1>
  <p>Từ trợ lý nhận lịch đơn giản đến trợ lý AI hiểu khách như nhân viên thật — đều chạy trên Zalo.</p>
  <p class="hero-note">✓ Miễn phí &nbsp;·&nbsp; ✓ Setup 1 ngày &nbsp;·&nbsp; ✓ Không cần kỹ thuật</p>
</section>

<!-- PLANS -->
<section class="sec white" id="plans">
  <div class="sec-label">Gói dịch vụ</div>
  <div class="sec-title">Chọn gói phù hợp với spa</div>
  <div class="sec-sub">Bắt đầu miễn phí, nâng cấp bất kỳ lúc nào</div>

  <div class="plans">

    <!-- BOT CƠ BẢN -->
    <div class="plan">
      <div class="plan-header">
        <div class="plan-badge badge-basic">🤖 Trợ lý cơ bản</div>
        <div class="plan-name basic">Trợ lý Tự Động</div>
        <div class="plan-desc">Nhận lịch hẹn, nhắc khách theo menu có sẵn. Phù hợp spa mới bắt đầu.</div>
        <div class="plan-price">0đ <span>/tháng</span></div>
        <div class="plan-price-note">Miễn phí hoàn toàn</div>
      </div>
      <div class="plan-divider"></div>
      <div class="plan-features">
        <div class="feat"><div class="ic ic-basic">✓</div><div class="label">Khách chọn dịch vụ qua nút bấm<small>Menu cố định, dễ dùng</small></div></div>
        <div class="feat"><div class="ic ic-basic">✓</div><div class="label">Đặt lịch theo khung giờ có sẵn<small>09:30 – 22:00, bước 30 phút</small></div></div>
        <div class="feat"><div class="ic ic-basic">✓</div><div class="label">Nhắc lịch tự động trước 2 tiếng<small>Tin nhắn Zalo tự động gửi đi</small></div></div>
        <div class="feat"><div class="ic ic-basic">✓</div><div class="label">Trang admin quản lý lịch hẹn</div></div>
        <div class="feat"><div class="ic ic-basic">✓</div><div class="label">Hoạt động trên Zalo</div></div>
      </div>
      <div class="plan-cta"><a href="#contact" class="btn-plan btn-basic">Dùng miễn phí →</a></div>
    </div>

    <!-- BOT AI -->
    <div class="plan featured">
      <div class="plan-header">
        <div class="plan-badge badge-ai">✨ Phổ biến nhất</div>
        <div class="plan-name ai">Trợ lý AI</div>
        <div class="plan-desc">AI hiểu tin nhắn tự nhiên, tư vấn dịch vụ thông minh theo nhu cầu từng khách.</div>
        <div class="plan-price">0đ <span>/tháng</span></div>
        <div class="plan-price-note">Miễn phí trong giai đoạn ra mắt</div>
      </div>
      <div class="plan-divider"></div>
      <div class="plan-features">
        <div class="feat"><div class="ic ic-ai">✓</div><div class="label">Tất cả tính năng Trợ lý cơ bản</div></div>
        <div class="feat"><div class="ic ic-ai">✦</div><div class="label">AI hiểu ngôn ngữ tự nhiên <span class="feat-new">AI</span><small>Khách nhắn bất kỳ, trợ lý vẫn hiểu</small></div></div>
        <div class="feat"><div class="ic ic-ai">✦</div><div class="label">Gợi ý dịch vụ phù hợp <span class="feat-new">AI</span><small>Dựa theo nhu cầu và lịch sử khách</small></div></div>
        <div class="feat"><div class="ic ic-ai">✓</div><div class="label">Lịch sử dịch vụ đã dùng<small>Khách xem lại trong chat</small></div></div>
        <div class="feat"><div class="ic ic-ai">✓</div><div class="label">Gửi khuyến mãi cho khách quen<small>Sinh nhật, lễ tết, chương trình mới</small></div></div>
        <div class="feat"><div class="ic ic-ai">✓</div><div class="label">Zalo + Telegram</div></div>
      </div>
      <div class="plan-cta"><a href="#contact" class="btn-plan btn-ai">Đăng ký ngay →</a></div>
    </div>

    <!-- BOT AI PRO -->
    <div class="plan pro-plan">
      <div class="plan-header">
        <div class="plan-badge badge-pro">🚀 Xịn nhất</div>
        <div class="plan-name pro">Trợ lý AI Pro</div>
        <div class="plan-desc">Trợ lý AI toàn diện — phân tích khách hàng, tự động marketing, báo cáo doanh thu.</div>
        <div class="plan-price">0đ <span>/tháng</span></div>
        <div class="plan-price-note">Miễn phí trong giai đoạn ra mắt</div>
      </div>
      <div class="plan-divider"></div>
      <div class="plan-features">
        <div class="feat"><div class="ic ic-pro">✓</div><div class="label">Tất cả tính năng Trợ lý AI</div></div>
        <div class="feat"><div class="ic ic-pro">🧠</div><div class="label">Phân tích hành vi khách hàng <span class="feat-new">PRO</span><small>Biết khách nào sắp rời bỏ để giữ chân</small></div></div>
        <div class="feat"><div class="ic ic-pro">📊</div><div class="label">Báo cáo doanh thu tự động <span class="feat-new">PRO</span><small>Thống kê ngày/tuần/tháng realtime</small></div></div>
        <div class="feat"><div class="ic ic-pro">🎯</div><div class="label">Remarketing tự động <span class="feat-new">PRO</span><small>Tự nhắn khách lâu không quay lại</small></div></div>
        <div class="feat"><div class="ic ic-pro">⭐</div><div class="label">Thu thập đánh giá sau dịch vụ <span class="feat-new">PRO</span><small>Tự gửi form review, tổng hợp sao</small></div></div>
        <div class="feat"><div class="ic ic-pro">👑</div><div class="label">Dashboard VIP toàn diện <span class="feat-new">PRO</span><small>Quản lý nhân viên, ca làm việc, KPI</small></div></div>
      </div>
      <div class="plan-cta"><a href="#contact" class="btn-plan btn-pro">Tôi muốn gói này →</a></div>
    </div>

  </div>
</section>

<!-- COMPARE TABLE -->
<section class="sec gray" id="compare">
  <div class="sec-label">So sánh</div>
  <div class="sec-title">Tính năng chi tiết từng gói</div>
  <div class="sec-sub">Xem đầy đủ để chọn đúng gói</div>

  <div class="compare">
    <table>
      <thead>
        <tr>
          <th>Tính năng</th>
          <th class="th-basic">🤖 Trợ lý</th>
          <th class="th-ai">✨ Trợ lý AI</th>
          <th class="th-pro">🚀 Trợ lý AI Pro</th>
        </tr>
      </thead>
      <tbody>
        <tr class="cat-row"><td colspan="4">Đặt lịch & Nhắc nhở</td></tr>
        <tr><td>Đặt lịch qua nút bấm</td><td><span class="ck-y">✓</span></td><td><span class="ck-y">✓</span></td><td><span class="ck-y">✓</span></td></tr>
        <tr><td>Đặt lịch bằng tin nhắn tự nhiên</td><td><span class="ck-n">—</span></td><td><span class="ck-y">✓</span></td><td><span class="ck-y">✓</span></td></tr>
        <tr><td>Nhắc lịch tự động trước 2 tiếng</td><td><span class="ck-y">✓</span></td><td><span class="ck-y">✓</span></td><td><span class="ck-y">✓</span></td></tr>
        <tr><td>Nhắc thêm trước 30 phút</td><td><span class="ck-n">—</span></td><td><span class="ck-y">✓</span></td><td><span class="ck-y">✓</span></td></tr>

        <tr class="cat-row"><td colspan="4">AI & Tư vấn thông minh</td></tr>
        <tr><td>AI hiểu ngôn ngữ tự nhiên</td><td><span class="ck-n">—</span></td><td><span class="ck-y">✓</span></td><td><span class="ck-y">✓</span></td></tr>
        <tr><td>Gợi ý dịch vụ theo nhu cầu</td><td><span class="ck-n">—</span></td><td><span class="ck-y">✓</span></td><td><span class="ck-y">✓</span></td></tr>
        <tr><td>Tư vấn combo tiết kiệm</td><td><span class="ck-n">—</span></td><td><span class="ck-n">—</span></td><td><span class="ck-p">✓</span></td></tr>
        <tr><td>Phân tích hành vi khách hàng</td><td><span class="ck-n">—</span></td><td><span class="ck-n">—</span></td><td><span class="ck-p">✓</span></td></tr>

