        <tr><td>Lịch sử dịch vụ đã dùng</td><td><span class="ck-n">—</span></td><td><span class="ck-y">✓</span></td><td><span class="ck-y">✓</span></td></tr>
        <tr><td>Gửi khuyến mãi dịp đặc biệt</td><td><span class="ck-n">—</span></td><td><span class="ck-y">✓</span></td><td><span class="ck-y">✓</span></td></tr>
        <tr><td>Remarketing khách lâu không quay lại</td><td><span class="ck-n">—</span></td><td><span class="ck-n">—</span></td><td><span class="ck-p">✓</span></td></tr>
        <tr><td>Thu thập đánh giá tự động</td><td><span class="ck-n">—</span></td><td><span class="ck-n">—</span></td><td><span class="ck-p">✓</span></td></tr>

        <tr class="cat-row"><td colspan="4">Quản lý & Báo cáo</td></tr>
        <tr><td>Trang admin quản lý lịch hẹn</td><td><span class="ck-y">✓</span></td><td><span class="ck-y">✓</span></td><td><span class="ck-y">✓</span></td></tr>
        <tr><td>Báo cáo doanh thu tự động</td><td><span class="ck-n">—</span></td><td><span class="ck-n">—</span></td><td><span class="ck-p">✓</span></td></tr>
        <tr><td>Quản lý nhân viên & ca làm việc</td><td><span class="ck-n">—</span></td><td><span class="ck-n">—</span></td><td><span class="ck-p">✓</span></td></tr>

        <tr class="cat-row"><td colspan="4">Nền tảng</td></tr>
        <tr><td>Zalo</td><td><span class="ck-y">✓</span></td><td><span class="ck-y">✓</span></td><td><span class="ck-y">✓</span></td></tr>
        <tr><td>Telegram</td><td><span class="ck-n">—</span></td><td><span class="ck-y">✓</span></td><td><span class="ck-y">✓</span></td></tr>
      </tbody>
    </table>
  </div>
</section>

<!-- DEMO CHAT -->
<section class="sec white" id="demo">
