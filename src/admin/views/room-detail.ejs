<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Phòng <%= room.roomNumber %> - Chi tiết</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: Arial, sans-serif; background: #f5f5f5; color: #333; }

    header { background: #2c7a4b; color: white; padding: 14px 20px; display: flex; align-items: center; gap: 12px; }
    header a { color: white; text-decoration: none; font-size: 20px; }
    header h1 { font-size: 18px; }

    .container { max-width: 800px; margin: 24px auto; padding: 0 16px; }

    /* Gallery */
    .gallery { background: #000; border-radius: 10px; overflow: hidden; margin-bottom: 20px; }
    .main-img-wrap { position: relative; width: 100%; aspect-ratio: 16/9; background: #111; display: flex; align-items: center; justify-content: center; }
    .main-img-wrap img { width: 100%; height: 100%; object-fit: cover; }
    .main-img-wrap .no-img { color: #555; font-size: 60px; }
    .nav-btn {
      position: absolute; top: 50%; transform: translateY(-50%);
      background: rgba(0,0,0,0.45); border: none; color: white;
      font-size: 28px; width: 44px; height: 44px; border-radius: 50%;
      cursor: pointer; display: flex; align-items: center; justify-content: center;
    }
    .nav-btn:hover { background: rgba(0,0,0,0.7); }
    .nav-btn.prev { left: 12px; }
    .nav-btn.next { right: 12px; }
    .img-counter {
      position: absolute; bottom: 10px; right: 14px;
      background: rgba(0,0,0,0.55); color: white; font-size: 13px;
      padding: 3px 10px; border-radius: 12px;
    }
    .thumbs { display: flex; gap: 6px; padding: 8px; overflow-x: auto; background: #1a1a1a; }
    .thumbs img {
      width: 70px; height: 55px; object-fit: cover; border-radius: 4px;
      cursor: pointer; opacity: 0.55; border: 2px solid transparent; flex-shrink: 0;
    }
    .thumbs img.active { opacity: 1; border-color: #2c7a4b; }

    /* Info card */
    .card { background: white; border-radius: 10px; padding: 20px; margin-bottom: 16px; box-shadow: 0 1px 4px rgba(0,0,0,0.1); }

    .room-header { display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 10px; margin-bottom: 16px; }
    .room-title { font-size: 22px; font-weight: bold; }
    .room-price { font-size: 22px; font-weight: bold; color: #2c7a4b; }
    .badge { display: inline-block; padding: 4px 12px; border-radius: 20px; font-size: 13px; font-weight: 500; }
    .badge-green { background: #d4edda; color: #155724; }
    .badge-red { background: #f8d7da; color: #721c24; }

    .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
    .info-item label { font-size: 12px; color: #888; display: block; margin-bottom: 3px; }
    .info-item span { font-size: 15px; font-weight: 500; }

    .description { background: #f9f9f9; border-radius: 6px; padding: 14px; font-size: 14px; line-height: 1.6; color: #555; margin-top: 16px; }

    .contact-card { background: #2c7a4b; color: white; border-radius: 10px; padding: 20px; text-align: center; }
    .contact-card p { font-size: 14px; opacity: 0.85; margin-bottom: 6px; }
    .contact-card .phone { font-size: 26px; font-weight: bold; letter-spacing: 1px; }
    .contact-card a { color: white; text-decoration: none; }
    .btn-call { display: inline-block; margin-top: 12px; background: white; color: #2c7a4b;
      padding: 10px 28px; border-radius: 25px; font-weight: bold; font-size: 15px; text-decoration: none; }
    .btn-call:hover { background: #f0faf5; }

    /* ── Mobile responsive ── */
    @media (max-width: 768px) {
      header { padding: 12px 14px; }
      header h1 { font-size: 16px; }

      .container { margin: 12px auto; padding: 0 10px; }
      .card { padding: 16px; margin-bottom: 14px; }

      .room-header { flex-direction: column; gap: 6px; }
      .room-title { font-size: 18px; }
      .room-price { font-size: 18px; }

      .info-grid { grid-template-columns: 1fr; gap: 10px; }

      .thumbs img { width: 56px; height: 44px; }

      .contact-card .phone { font-size: 22px; }
      .btn-call { display: block; text-align: center; padding: 12px; font-size: 16px; }

      input, select { font-size: 16px; } /* tránh zoom iOS */
    }
  </style>
</head>
<body>
  <header>
    <a href="javascript:history.back()">←</a>
    <h1>Chi tiết Phòng <%= room.roomNumber %></h1>
  </header>

  <div class="container">

    <!-- Gallery ảnh -->
    <div class="gallery">
      <div class="main-img-wrap" id="mainImgWrap">
        <% if (room.images && room.images.length > 0) { %>
          <img id="mainImg" src="<%= room.images[0] %>" alt="Phòng <%= room.roomNumber %>">
          <% if (room.images.length > 1) { %>
            <button class="nav-btn prev" onclick="prevImg()">‹</button>
            <button class="nav-btn next" onclick="nextImg()">›</button>
          <% } %>
          <div class="img-counter" id="imgCounter">1 / <%= room.images.length %></div>
        <% } else { %>
          <div class="no-img">🏠</div>
        <% } %>
      </div>
      <% if (room.images && room.images.length > 1) { %>
      <div class="thumbs" id="thumbs">
        <% room.images.forEach((img, i) => { %>
          <img src="<%= img %>" class="<%= i === 0 ? 'active' : '' %>" onclick="jumpTo(<%= i %>)">
        <% }) %>
      </div>
      <% } %>
    </div>

    <!-- Thông tin phòng -->
    <div class="card">
      <div class="room-header">
        <div>
          <div class="room-title">🏠 Phòng <%= room.roomNumber %></div>
          <div style="margin-top:6px">
            <span class="badge <%= room.status === 'available' ? 'badge-green' : 'badge-red' %>">
              <%= room.status === 'available' ? '✅ Còn trống' : '❌ Đã có người thuê' %>
            </span>
          </div>
        </div>
        <div class="room-price">
          <%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(room.price) %>/tháng
        </div>
      </div>

      <div class="info-grid">
        <div class="info-item">
          <label>📍 Địa chỉ</label>
          <span><%= room.address %></span>
        </div>
        <div class="info-item">
          <label>🗺 Khu vực</label>
          <span><%= room.district %></span>
        </div>
        <div class="info-item">
          <label>📐 Diện tích</label>
          <span><%= room.area %> m²</span>
        </div>
        <div class="info-item">
          <label>🛋 Nội thất</label>
          <span><%= room.furniture === 'none' ? 'Không nội thất' : room.furniture === 'basic' ? 'Nội thất cơ bản' : 'Đầy đủ nội thất' %></span>
        </div>
      </div>

      <% if (room.description) { %>
        <div class="description">📝 <%= room.description %></div>
      <% } %>
    </div>

    <!-- Liên hệ -->
    <div class="contact-card">
      <p>Liên hệ đặt xem phòng</p>
      <div class="phone"><a href="tel:<%= room.contact.replace(/\s/g,'') %>"><%= room.contact %></a></div>
      <a href="tel:<%= room.contact.replace(/\s/g,'') %>" class="btn-call">📞 Gọi ngay</a>
    </div>

  </div>

  <script>
    const images = <%- JSON.stringify(room.images || []) %>;
    let current = 0;

    function renderImg() {
      document.getElementById('mainImg').src = images[current];
      document.getElementById('imgCounter').textContent = `${current + 1} / ${images.length}`;
      document.querySelectorAll('#thumbs img').forEach((el, i) => {
        el.classList.toggle('active', i === current);
      });
    }
    function prevImg() { current = (current - 1 + images.length) % images.length; renderImg(); }
    function nextImg() { current = (current + 1) % images.length; renderImg(); }
    function jumpTo(i) { current = i; renderImg(); }

    // Swipe trên mobile
    let startX = 0;
    const wrap = document.getElementById('mainImgWrap');
    if (wrap) {
      wrap.addEventListener('touchstart', e => startX = e.touches[0].clientX);
      wrap.addEventListener('touchend', e => {
        const diff = startX - e.changedTouches[0].clientX;
        if (Math.abs(diff) > 40) diff > 0 ? nextImg() : prevImg();
      });
    }
  </script>
</body>
</html>
