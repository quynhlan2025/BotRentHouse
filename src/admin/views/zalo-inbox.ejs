<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Zalo Inbox – Quản lý hội thoại</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --zblue: #0068ff; --zblueli: #e8f0ff;
      --bg: #f0f2f5; --card: #fff;
      --text: #1a1a1a; --muted: #888; --border: #e4e6eb;
    }
    body { font-family: 'Segoe UI', Arial, sans-serif; background: var(--bg); color: var(--text); height: 100vh; display: flex; flex-direction: column; overflow: hidden; }

    /* TOP NAV */
    .topbar {
      height: 54px; background: var(--zblue); color: white;
      display: flex; align-items: center; padding: 0 20px; gap: 14px;
      box-shadow: 0 2px 8px rgba(0,104,255,.3); flex-shrink: 0;
    }
    .topbar .zlogo { width: 30px; height: 30px; background: white; border-radius: 8px; display: flex; align-items: center; justify-content: center; color: var(--zblue); font-weight: 900; font-size: 16px; font-style: italic; }
    .topbar h1 { font-size: 17px; font-weight: 700; }
    .topbar .back { margin-left: auto; font-size: 13px; opacity: .85; color: white; text-decoration: none; }
    .topbar .back:hover { opacity: 1; }

    /* LAYOUT */
    .layout { display: flex; flex: 1; overflow: hidden; }

    /* LEFT: user list */
    .sidebar {
      width: 300px; flex-shrink: 0; background: white;
      border-right: 1px solid var(--border); display: flex; flex-direction: column;
      overflow: hidden;
    }
    .sidebar-header { padding: 14px 16px; border-bottom: 1px solid var(--border); }
    .sidebar-header h2 { font-size: 15px; font-weight: 700; margin-bottom: 10px; }
    .search-box {
      width: 100%; padding: 8px 14px; border: 1px solid var(--border);
      border-radius: 20px; font-size: 13px; background: var(--bg); outline: none;
    }
    .search-box:focus { border-color: var(--zblue); }
    .user-list { overflow-y: auto; flex: 1; }
    .user-item {
      display: flex; align-items: center; gap: 12px;
      padding: 12px 16px; cursor: pointer; border-bottom: 1px solid #f5f5f5;
      transition: background .1s; text-decoration: none; color: var(--text);
    }
    .user-item:hover { background: var(--bg); }
    .user-item.active { background: var(--zblueli); border-left: 3px solid var(--zblue); }
    .user-av {
      width: 42px; height: 42px; border-radius: 50%; flex-shrink: 0;
      background: var(--zblue); display: flex; align-items: center; justify-content: center;
      color: white; font-weight: 700; font-size: 16px; overflow: hidden;
    }
    .user-av img { width: 100%; height: 100%; object-fit: cover; }
    .user-info { flex: 1; min-width: 0; }
    .user-name { font-size: 14px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .user-last { font-size: 12px; color: var(--muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-top: 2px; }
    .user-meta { display: flex; flex-direction: column; align-items: flex-end; gap: 4px; flex-shrink: 0; }
    .user-time { font-size: 11px; color: var(--muted); }
    .unread-badge { background: var(--zblue); color: white; border-radius: 10px; font-size: 10px; font-weight: 700; padding: 1px 7px; min-width: 18px; text-align: center; }
    .empty-list { padding: 40px 20px; text-align: center; color: var(--muted); font-size: 14px; }

    /* RIGHT: chat panel */
    .chat-panel { flex: 1; display: flex; flex-direction: column; overflow: hidden; background: var(--bg); }

    .chat-header {
      background: white; border-bottom: 1px solid var(--border);
      padding: 12px 20px; display: flex; align-items: center; gap: 12px; flex-shrink: 0;
    }
    .chat-header .ch-av {
      width: 38px; height: 38px; border-radius: 50%; background: var(--zblue);
      display: flex; align-items: center; justify-content: center; color: white; font-weight: 700; overflow: hidden;
    }
    .chat-header .ch-av img { width: 100%; height: 100%; object-fit: cover; }
    .chat-header .ch-name { font-size: 15px; font-weight: 700; }
    .chat-header .ch-id   { font-size: 11px; color: var(--muted); margin-top: 1px; }
    .chat-header .ch-actions { margin-left: auto; display: flex; align-items: center; gap: 8px; }
    .ch-badge { background: var(--zblueli); color: var(--zblue); font-size: 11px; font-weight: 700; padding: 4px 12px; border-radius: 20px; }
    .ch-badge.takeover { background: #fef3c7; color: #92400e; }
    .btn-takeover { padding: 7px 14px; border-radius: 8px; font-size: 12px; font-weight: 700; border: none; cursor: pointer; }
    .btn-takeover.take { background: #f59e0b; color: white; }
    .btn-takeover.give { background: var(--zblue); color: white; }

    .chat-messages { flex: 1; overflow-y: auto; padding: 20px 24px; display: flex; flex-direction: column; gap: 10px; }
    .day-divider { text-align: center; font-size: 11px; color: var(--muted); background: rgba(0,0,0,.06); padding: 3px 12px; border-radius: 10px; align-self: center; margin: 4px 0; }

    .msg-row { display: flex; gap: 8px; max-width: 70%; }
    .msg-row.user { align-self: flex-end; flex-direction: row-reverse; }
    .msg-row.bot  { align-self: flex-start; }
    .msg-av-sm { width: 28px; height: 28px; border-radius: 50%; background: var(--zblue); display: flex; align-items: center; justify-content: center; color: white; font-size: 12px; font-weight: 700; flex-shrink: 0; align-self: flex-end; }
    .msg-bubble {
      padding: 9px 13px; border-radius: 18px; font-size: 13.5px; line-height: 1.55;
      max-width: 100%; word-break: break-word;
    }
    .msg-row.user .msg-bubble { background: var(--zblue); color: white; border-bottom-right-radius: 4px; }
    .msg-row.bot  .msg-bubble { background: white; color: var(--text); border-bottom-left-radius: 4px; box-shadow: 0 1px 2px rgba(0,0,0,.08); }
    .msg-time { font-size: 10px; color: var(--muted); margin-top: 4px; text-align: right; }
    .msg-row.bot .msg-time { text-align: left; }

    /* Reply bar */
    .reply-bar {
      background: white; border-top: 1px solid var(--border);
      padding: 12px 16px; display: flex; gap: 10px; align-items: center; flex-shrink: 0;
    }
    .reply-input {
      flex: 1; background: var(--bg); border: 1px solid var(--border);
      border-radius: 22px; padding: 10px 16px; font-size: 14px; outline: none; resize: none;
    }
    .reply-input:focus { border-color: var(--zblue); }
    .send-btn {
      width: 40px; height: 40px; background: var(--zblue); border: none; border-radius: 50%;
      color: white; font-size: 16px; cursor: pointer; display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .send-btn:hover { background: #0058d4; }

    /* Empty state */
    .empty-state { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; color: var(--muted); gap: 12px; }
    .empty-state .icon { font-size: 56px; opacity: .4; }
    .empty-state p { font-size: 15px; }

    @media (max-width: 680px) {
      .sidebar { width: 100%; display: <%= selectedUser ? 'none' : 'flex' %>; }
      .chat-panel { display: <%= selectedUser ? 'flex' : 'none' %>; }
    }
  </style>
</head>
<body>

<div class="topbar">
  <div class="zlogo">Z</div>
  <h1>Zalo Inbox</h1>
  <a href="/admin" class="back">← Admin</a>
</div>

<div class="layout">

  <!-- SIDEBAR -->
  <div class="sidebar">
    <div class="sidebar-header">
      <h2>Hội thoại (<%= conversations.length %>)</h2>
      <input class="search-box" type="text" placeholder="🔍 Tìm tên khách..." id="searchInput" oninput="filterUsers()">
    </div>
    <div class="user-list" id="userList">
      <% if (conversations.length === 0) { %>
      <div class="empty-list">Chưa có hội thoại nào</div>
      <% } %>
      <% conversations.forEach(c => { %>
      <a class="user-item <%= selectedUser && selectedUser.zaloUserId === c.zaloUserId ? 'active' : '' %>"
         href="/zalo-inbox?user=<%= c.zaloUserId %>"
         data-name="<%= c.displayName.toLowerCase() %>">
        <div class="user-av">
          <% if (c.avatar) { %><img src="<%= c.avatar %>"><% } else { %><%= c.displayName.charAt(0).toUpperCase() %><% } %>
        </div>
        <div class="user-info">
          <div class="user-name"><%= c.displayName %></div>
          <div class="user-last"><%= c.lastMessage ? c.lastMessage.substring(0,40) + (c.lastMessage.length > 40 ? '…' : '') : 'Chưa có tin nhắn' %></div>
        </div>
        <div class="user-meta">
          <div class="user-time"><%= c.lastMessageAt ? new Date(c.lastMessageAt).toLocaleTimeString('vi-VN', {hour:'2-digit', minute:'2-digit'}) : '' %></div>
          <% if (c.unread > 0) { %><div class="unread-badge"><%= c.unread %></div><% } %>
        </div>
      </a>
      <% }) %>
    </div>
  </div>

  <!-- CHAT PANEL -->
  <div class="chat-panel">
    <% if (selectedUser) { %>

    <div class="chat-header">
      <div class="ch-av">
        <% if (selectedUser.avatar) { %><img src="<%= selectedUser.avatar %>"><% } else { %><%= selectedUser.displayName.charAt(0).toUpperCase() %><% } %>
      </div>
      <div>
        <div class="ch-name"><%= selectedUser.displayName %></div>
        <div class="ch-id">
          <%= selectedUser.phone ? '📱 ' + selectedUser.phone + ' · ' : '' %>ID: <%= selectedUser.zaloUserId %>
        </div>
      </div>
      <div class="ch-actions">
        <% if (selectedUser.takenOver) { %>
          <span class="ch-badge takeover">👤 Admin đang tiếp quản</span>
          <button class="btn-takeover give" onclick="setTakeover(false)">🤖 Trả lại bot</button>
        <% } else { %>
          <span class="ch-badge">🤖 Bot đang trả lời</span>
          <button class="btn-takeover take" onclick="setTakeover(true)">👤 Tiếp quản</button>
        <% } %>
      </div>
    </div>

    <div class="chat-messages" id="chatMessages">
      <% let lastDate = null; %>
      <% selectedUser.messages.forEach(msg => { %>
        <% const msgDate = new Date(msg.createdAt).toLocaleDateString('vi-VN'); %>
        <% if (msgDate !== lastDate) { lastDate = msgDate; %>
        <div class="day-divider"><%= msgDate %></div>
        <% } %>
        <div class="msg-row <%= msg.role %>">
          <% if (msg.role === 'bot') { %>
          <div class="msg-av-sm">Z</div>
          <% } %>
          <div>
            <div class="msg-bubble"><%= msg.text.replace(/\n/g, '<br>') %></div>
            <div class="msg-time"><%= new Date(msg.createdAt).toLocaleTimeString('vi-VN', {hour:'2-digit', minute:'2-digit'}) %></div>
          </div>
        </div>
      <% }) %>
    </div>

    <div class="reply-bar">
      <% if (selectedUser.takenOver) { %>
      <span style="font-size:11px;color:#92400e;font-weight:700;white-space:nowrap;">👤 Admin:</span>
      <% } else { %>
      <span style="font-size:11px;color:var(--zblue);font-weight:700;white-space:nowrap;">🤖 Bot:</span>
      <% } %>
      <textarea class="reply-input" id="replyInput"
        placeholder="<%= selectedUser.takenOver ? 'Bạn đang nhắn với tư cách Admin...' : 'Reply sẽ gửi qua bot...' %>"
        rows="1"
        onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();sendReply();}"></textarea>
      <button class="send-btn" onclick="sendReply()">➤</button>
    </div>

    <% } else { %>
    <div class="empty-state">
      <div class="icon">💬</div>
      <p>Chọn một hội thoại để xem</p>
    </div>
    <% } %>
  </div>

</div>

<script>
  // Auto scroll to bottom
  const msgs = document.getElementById('chatMessages');
  if (msgs) msgs.scrollTop = msgs.scrollHeight;

  // Search
  function filterUsers() {
    const q = document.getElementById('searchInput').value.toLowerCase();
    document.querySelectorAll('.user-item').forEach(el => {
      el.style.display = el.dataset.name.includes(q) ? '' : 'none';
    });
  }

  // Tiếp quản / trả bot
  async function setTakeover(val) {
    const userId = '<%= selectedUser ? selectedUser.zaloUserId : "" %>';
    await fetch('/zalo-inbox/takeover', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ userId, takenOver: val }),
    });
    location.reload();
  }

  // Send reply
  async function sendReply() {
    const input = document.getElementById('replyInput');
    const text  = input.value.trim();
    if (!text) return;
    input.value = '';

    const userId = '<%= selectedUser ? selectedUser.zaloUserId : "" %>';
    try {
      await fetch('/zalo-inbox/send', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userId, text }),
      });
      // Reload to show new message
      location.reload();
    } catch (e) {
      alert('Gửi thất bại: ' + e.message);
    }
  }

  // Mark as read when opening a conversation
  <% if (selectedUser && selectedUser.unread > 0) { %>
  fetch('/zalo-inbox/read', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ userId: '<%= selectedUser.zaloUserId %>' }),
  });
  <% } %>
</script>
</body>
</html>
