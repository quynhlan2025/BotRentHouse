<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Quản lý Sự cố & Sửa chữa</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Segoe UI', Arial, sans-serif; background: #f5f7fa; color: #1a1a1a; }

    /* NAV */
    nav {
      background: #1a5c35; color: white; padding: 0 24px; height: 56px;
      display: flex; align-items: center; justify-content: space-between;
      box-shadow: 0 2px 8px rgba(0,0,0,.15);
    }
    .nav-logo { font-size: 17px; font-weight: 800; display: flex; align-items: center; gap: 8px; }
    .nav-links { display: flex; gap: 6px; }
    .nav-links a {
      color: rgba(255,255,255,.8); text-decoration: none; font-size: 13px;
      padding: 6px 12px; border-radius: 7px; transition: background .15s;
    }
    .nav-links a:hover, .nav-links a.active { background: rgba(255,255,255,.15); color: white; }

    /* MAIN */
    .main { max-width: 1100px; margin: 0 auto; padding: 28px 20px; }
    .page-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; flex-wrap: wrap; gap: 12px; }
    .page-header h1 { font-size: 22px; font-weight: 800; }
    .page-header h1 span { color: #2c7a4b; }

    /* FLASH */
    .flash { background: #d1fae5; color: #065f46; border: 1px solid #6ee7b7; border-radius: 10px; padding: 11px 16px; margin-bottom: 20px; font-size: 14px; }

    /* STATS */
    .stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin-bottom: 24px; }
    .stat-card { background: white; border-radius: 14px; padding: 18px 20px; border: 1px solid #eee; text-align: center; cursor: pointer; text-decoration: none; transition: box-shadow .15s; }
    .stat-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,.08); }
    .stat-card.active { border-color: #2c7a4b; box-shadow: 0 0 0 2px #2c7a4b22; }
    .stat-num { font-size: 28px; font-weight: 900; }
    .stat-label { font-size: 12px; color: #888; margin-top: 4px; }
    .num-all        { color: #1a1a1a; }
    .num-pending    { color: #f59e0b; }
    .num-processing { color: #3b82f6; }
    .num-done       { color: #10b981; }

    /* TABLE */
    .card { background: white; border-radius: 16px; border: 1px solid #eee; overflow: hidden; }
    table { width: 100%; border-collapse: collapse; }
    thead th { background: #f9fafb; padding: 12px 16px; text-align: left; font-size: 12px; color: #888; font-weight: 700; text-transform: uppercase; letter-spacing: .5px; border-bottom: 1px solid #eee; }
    tbody tr { border-bottom: 1px solid #f3f4f6; transition: background .1s; }
    tbody tr:last-child { border-bottom: none; }
    tbody tr:hover { background: #fafafa; }
    td { padding: 14px 16px; font-size: 14px; vertical-align: top; }

    .badge {
      display: inline-block; padding: 3px 10px; border-radius: 20px;
      font-size: 11px; font-weight: 700;
    }
    .badge-pending    { background: #fef9c3; color: #854d0e; }
    .badge-processing { background: #dbeafe; color: #1e40af; }
    .badge-done       { background: #d1fae5; color: #065f46; }

    .desc { color: #374151; line-height: 1.5; }
    .note-text { font-size: 12px; color: #888; margin-top: 3px; font-style: italic; }
    .meta { font-size: 12px; color: #aaa; margin-top: 3px; }

    /* FORM */
    .actions { display: flex; gap: 6px; align-items: flex-start; flex-wrap: wrap; }
    select.sel-status {
      font-size: 12px; padding: 5px 8px; border: 1px solid #e5e7eb;
      border-radius: 7px; background: white; color: #374151; cursor: pointer;
    }
    input.inp-note {
      font-size: 12px; padding: 5px 8px; border: 1px solid #e5e7eb;
      border-radius: 7px; width: 140px; color: #374151;
    }
    .btn-save {
      background: #2c7a4b; color: white; border: none; padding: 6px 12px;
      border-radius: 7px; font-size: 12px; font-weight: 600; cursor: pointer;
    }
    .btn-save:hover { background: #235e3a; }
    .btn-del {
      background: #fee2e2; color: #991b1b; border: none; padding: 6px 10px;
      border-radius: 7px; font-size: 12px; cursor: pointer;
    }
    .btn-del:hover { background: #fecaca; }

    .empty { text-align: center; padding: 60px 20px; color: #aaa; }
    .empty .icon { font-size: 40px; margin-bottom: 10px; }

    @media (max-width: 768px) {
      .stats { grid-template-columns: repeat(2, 1fr); }
      thead { display: none; }
      tbody tr { display: block; padding: 14px 16px; border-bottom: 1px solid #eee; }
      td { display: block; padding: 3px 0; border: none; }
      td::before { content: attr(data-label); font-size: 11px; color: #aaa; display: block; }
    }
  </style>
</head>
<body>

<nav>
  <div class="nav-logo">🔧 Sự cố & Sửa chữa</div>
  <div class="nav-links">
    <a href="/admin">🏠 Phòng trọ</a>
    <a href="/zalo-inbox">💬 Zalo Inbox</a>
    <a href="/admin/maintenance" class="active">🔧 Sự cố</a>
  </div>
</nav>

<div class="main">
  <div class="page-header">
    <h1>Quản lý <span>Sự cố & Sửa chữa</span></h1>
  </div>

  <% if (msg) { %>
    <div class="flash">✅ <%= msg %></div>
  <% } %>

  <!-- STATS -->
  <div class="stats">
    <a href="/admin/maintenance" class="stat-card <%= filter === 'all' ? 'active' : '' %>">
      <div class="stat-num num-all"><%= counts.all %></div>
      <div class="stat-label">Tất cả</div>
    </a>
    <a href="/admin/maintenance?status=pending" class="stat-card <%= filter === 'pending' ? 'active' : '' %>">
      <div class="stat-num num-pending"><%= counts.pending %></div>
      <div class="stat-label">⏳ Chờ xử lý</div>
    </a>
    <a href="/admin/maintenance?status=processing" class="stat-card <%= filter === 'processing' ? 'active' : '' %>">
      <div class="stat-num num-processing"><%= counts.processing %></div>
      <div class="stat-label">🔨 Đang xử lý</div>
    </a>
    <a href="/admin/maintenance?status=done" class="stat-card <%= filter === 'done' ? 'active' : '' %>">
      <div class="stat-num num-done"><%= counts.done %></div>
      <div class="stat-label">✅ Xong</div>
    </a>
  </div>

  <!-- TABLE -->
  <div class="card">
    <% if (requests.length === 0) { %>
      <div class="empty">
        <div class="icon">🎉</div>
        <div>Không có sự cố nào<% if (filter !== 'all') { %> ở trạng thái này<% } %>!</div>
      </div>
    <% } else { %>
    <table>
      <thead>
        <tr>
          <th>Khách</th>
          <th>Phòng</th>
          <th>Mô tả sự cố</th>
          <th>Trạng thái</th>
          <th>Thời gian</th>
          <th>Cập nhật</th>
        </tr>
      </thead>
      <tbody>
        <% requests.forEach(r => { %>
        <tr>
          <td data-label="Khách">
            <div style="font-weight:700"><%= r.displayName %></div>
            <% if (r.phone) { %><div class="meta">📞 <%= r.phone %></div><% } %>
          </td>
          <td data-label="Phòng">
            <b>Phòng <%= r.roomNumber || '?' %></b>
          </td>
          <td data-label="Mô tả">
            <div class="desc"><%= r.description %></div>
            <% if (r.note) { %><div class="note-text">📝 <%= r.note %></div><% } %>
          </td>
          <td data-label="Trạng thái">
            <% if (r.status === 'pending') { %>
              <span class="badge badge-pending">⏳ Chờ xử lý</span>
            <% } else if (r.status === 'processing') { %>
              <span class="badge badge-processing">🔨 Đang xử lý</span>
            <% } else { %>
              <span class="badge badge-done">✅ Xong</span>
            <% } %>
          </td>
          <td data-label="Thời gian">
            <div class="meta"><%= new Date(r.createdAt).toLocaleString('vi-VN') %></div>
          </td>
          <td data-label="Cập nhật">
            <div class="actions">
              <form method="POST" action="/admin/maintenance/<%= r._id %>/status" style="display:flex;gap:5px;flex-wrap:wrap">
                <select name="status" class="sel-status">
                  <option value="pending"    <%= r.status==='pending'    ? 'selected' : '' %>>⏳ Chờ xử lý</option>
                  <option value="processing" <%= r.status==='processing' ? 'selected' : '' %>>🔨 Đang xử lý</option>
                  <option value="done"       <%= r.status==='done'       ? 'selected' : '' %>>✅ Xong</option>
                </select>
                <input type="text" name="note" class="inp-note" placeholder="Ghi chú..." value="<%= r.note %>">
                <button type="submit" class="btn-save">Lưu</button>
              </form>
              <form method="POST" action="/admin/maintenance/<%= r._id %>/delete" onsubmit="return confirm('Xóa yêu cầu này?')">
                <button type="submit" class="btn-del">🗑</button>
              </form>
            </div>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% } %>
  </div>
</div>

</body>
</html>
